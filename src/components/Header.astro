---
// The Header is shared with /accounting (which passes page="accounting"
// to switch the scarcity bar + nav links). On the main site (page="main"),
// no accounting link is shown anywhere.
interface Props {
  page?: 'main' | 'accounting';
}
const { page = 'main' } = Astro.props;

// Single source of truth for the "next batch" banner.
// Update when seats fill or a new batch opens.
const nextBatch = {
  dayLabel: 'Mon Jun 1',
  track: 'DevOps',
  seatsLeft: 2,
  seatsTotal: 4,
};
---

<!-- Scarcity / deadline bar -->
{page === 'main' && (
  <div class="scarcity" role="region" aria-label="Next batch availability">
    <div class="container inner">
      <span class="pulse">Live</span>
      <span class="sep">/</span>
      <span><b>Next batch:</b> {nextBatch.dayLabel} &middot; {nextBatch.track} &middot; <b>{nextBatch.seatsLeft} of {nextBatch.seatsTotal} seats left</b></span>
      <span class="sep hide-sm">/</span>
      <a href="#batches" class="hide-sm">See all batches &rarr;</a>
    </div>
  </div>
)}
{page === 'accounting' && (
  <div class="scarcity acct" role="region" aria-label="Filing deadline">
    <div class="container inner">
      <span class="pulse">Tax season open</span>
      <span class="sep">/</span>
      <span><b>T1 deadline:</b> Apr&nbsp;30 &middot; <b>Self-employed:</b> Jun&nbsp;15 &middot; <b>T2:</b> 6&nbsp;mo after year-end</span>
      <span class="sep hide-sm">/</span>
      <a href="#pricing" class="hide-sm">See flat fees &rarr;</a>
    </div>
  </div>
)}

<!-- Header -->
<header class="site-header" data-screen-label="Header">
  <div class="container inner">
    <a href="/" class="brand"><span class="y">Y</span> Yarova</a>
    <nav class="nav-links" aria-label="Primary">
      {page === 'main' && <>
        <a href="/#how">How it works</a>
        <a href="/#batches">Batches</a>
        <a href="/#support">Support</a>
        <a href="/#pricing">Pricing</a>
        <a href="/#faq">FAQ</a>
        <a href="https://cal.com/yarova-fxqeea/discovery-call" target="_blank" rel="noopener" data-cal-link="yarova-fxqeea/discovery-call" data-cal-namespace="discovery-call" data-cal-config='{"layout":"month_view"}' class="btn btn-amber">Book a call <span class="arrow">&rarr;</span></a>
      </>}
      {page === 'accounting' && <>
        <a href="#pricing">Pricing</a>
        <a href="#process">Process</a>
        <a href="#trust">Why Yarova</a>
        <a href="#faq">FAQ</a>
        <a href="https://cal.com/yarova-fxqeea/tax-consult" target="_blank" rel="noopener" data-cal-link="yarova-fxqeea/tax-consult" data-cal-namespace="tax-consult" data-cal-config='{"layout":"month_view"}' class="btn btn-amber">Book your filing <span class="arrow">&rarr;</span></a>
      </>}
    </nav>
  </div>
</header>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

  /* Scarcity bar */
  .scarcity { background: var(--color-black); color: var(--color-gray-300); }
  .scarcity .inner { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 10px 24px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .04em; text-align: center; flex-wrap: wrap; }
  .scarcity b { color: white; font-weight: 600; }
  .scarcity .pulse { display: inline-flex; align-items: center; gap: 8px; color: var(--color-amber); font-weight: 600; text-transform: uppercase; letter-spacing: .14em; }
  .scarcity .pulse::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--color-amber); box-shadow: 0 0 0 0 rgba(245,158,11,.5); animation: pulse 1.8s infinite; }
  .scarcity.acct .pulse { color: #34D399; }
  .scarcity.acct .pulse::before { background: #34D399; box-shadow: 0 0 0 0 rgba(52,211,153,.7); }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(245,158,11,.5); } 70% { box-shadow: 0 0 0 8px rgba(245,158,11,0); } 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0); } }
  .scarcity a { color: var(--color-amber); }
  .scarcity .sep { color: #3A3A3D; }
  @media (max-width: 700px) { .scarcity .hide-sm { display: none; } }

  /* Header */
  .site-header { position: sticky; top: 0; z-index: 50; background: rgba(250,250,249,.86); backdrop-filter: saturate(150%) blur(14px); -webkit-backdrop-filter: saturate(150%) blur(14px); border-bottom: 1px solid var(--border); }
  .site-header .inner { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; gap: 24px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; color: var(--fg-1); letter-spacing: -.02em; text-decoration: none; }
  .brand .y { width: 26px; height: 26px; display: inline-flex; align-items: center; justify-content: center; background: var(--color-black); color: white; border-radius: 6px; font-weight: 700; font-size: 14px; letter-spacing: -.02em; }
  .brand:hover { color: var(--fg-1); }
  .nav-links { display: flex; align-items: center; gap: 22px; }
  .nav-links a:not(.btn) { color: var(--fg-2); font-size: 14px; font-weight: 500; text-decoration: none; }
  .nav-links a:not(.btn):hover { color: var(--fg-1); }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 999px; font-family: var(--font-sans); font-size: 14px; font-weight: 600; line-height: 1; border: 1px solid transparent; cursor: pointer; text-decoration: none; transition: all 150ms ease; }
  .btn-amber { background: var(--color-amber-hover); color: #FFFFFF !important; }
  .btn-amber:hover { background: var(--color-amber-press); color: #FFFFFF !important; }
  .arrow { transition: transform 180ms ease; display: inline-block; }
  .btn:hover .arrow { transform: translateX(3px); }
  @media (max-width: 880px) { .nav-links a:not(.btn) { display: none; } }
</style>

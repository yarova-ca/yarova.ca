---
// No props — single product, single nav
---

<!-- Top bar -->
<div class="top-bar" role="region" aria-label="Program availability">
  <div class="container inner">
    <span class="pulse">Live</span>
    <span class="sep">/</span>
    <span>DevOps &amp; SRE &middot; Canada &middot; <b>$799/month</b> &middot; Month to month</span>
    <span class="sep hide-sm">/</span>
    <a href="#book" class="hide-sm">Book a free call &rarr;</a>
  </div>
</div>

<!-- Header -->
<header class="site-header" data-screen-label="Header">
  <div class="container inner">
    <a href="/" class="brand"><span class="y">Y</span> Yarova</a>
    <nav class="nav-links" aria-label="Primary">
      <a href="#how-it-works">How It Works</a>
      <a href="#tracks">Tracks</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
      <a href="https://cal.com/yarova-fxqeea/discovery-call"
         target="_blank" rel="noopener"
         data-cal-link="yarova-fxqeea/discovery-call"
         data-cal-namespace="discovery-call"
         data-cal-config='{"layout":"month_view"}'
         class="btn btn-amber">Book a Free Call <span class="arrow">&rarr;</span></a>
    </nav>
  </div>
</header>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

  /* Top bar */
  .top-bar { background: var(--color-black); color: var(--color-gray-300); }
  .top-bar .inner { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 10px 24px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .04em; text-align: center; flex-wrap: wrap; }
  .top-bar b { color: white; font-weight: 600; }
  .top-bar a { color: var(--color-amber); }
  .pulse { display: inline-flex; align-items: center; gap: 8px; color: var(--color-amber); font-weight: 600; text-transform: uppercase; letter-spacing: .14em; }
  .pulse::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--color-amber); box-shadow: 0 0 0 0 rgba(245,158,11,.5); animation: pulse 1.8s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(245,158,11,.5); } 70% { box-shadow: 0 0 0 8px rgba(245,158,11,0); } 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0); } }
  .sep { color: #3A3A3D; }
  @media (max-width: 700px) { .top-bar .hide-sm { display: none; } }

  /* Header */
  .site-header { position: sticky; top: 0; z-index: 50; background: rgba(250,250,249,.9); backdrop-filter: saturate(150%) blur(14px); -webkit-backdrop-filter: saturate(150%) blur(14px); border-bottom: 1px solid var(--border); }
  .site-header .inner { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; gap: 24px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; color: var(--fg-1); letter-spacing: -.02em; text-decoration: none; }
  .brand .y { width: 26px; height: 26px; display: inline-flex; align-items: center; justify-content: center; background: var(--color-black); color: white; border-radius: 6px; font-weight: 700; font-size: 14px; }
  .brand:hover { color: var(--fg-1); }
  .nav-links { display: flex; align-items: center; gap: 22px; }
  .nav-links a:not(.btn) { color: var(--fg-2); font-size: 14px; font-weight: 500; text-decoration: none; transition: color 150ms ease; }
  .nav-links a:not(.btn):hover { color: var(--fg-1); }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 999px; font-family: var(--font-sans); font-size: 14px; font-weight: 600; line-height: 1; border: 1px solid transparent; cursor: pointer; text-decoration: none; transition: all 150ms ease; }
  .btn-amber { background: var(--color-amber-hover); color: #FFFFFF !important; }
  .btn-amber:hover { background: var(--color-amber-press); }
  .arrow { transition: transform 180ms ease; display: inline-block; }
  .btn:hover .arrow { transform: translateX(3px); }
  @media (max-width: 880px) { .nav-links a:not(.btn) { display: none; } }
</style>

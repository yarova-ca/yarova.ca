---
const today = new Date();
---

<!-- Contact strip -->
<section class="contact-strip" data-screen-label="Contact" aria-label="Contact Yarova">
  <div class="container">
    <div class="inner">
      <div class="cell">
        <span class="lbl">Book a fit call</span>
        <span class="val"><a href="https://cal.com/yarova/fit-call" target="_blank" rel="noopener" data-cal-link="yarova/fit-call" data-cal-namespace="fit-call">cal.com/yarova/fit-call</a></span>
        <span class="sub">30 min &middot; no deposit &middot; cohort calendar shared on the call</span>
      </div>
      <div class="cell">
        <span class="lbl">WhatsApp Business</span>
        <span class="val"><a href="https://wa.me/16047197918?text=Hi%20Yarova%2C%20I%27d%20like%20to%20learn%20about%20the%20placement%20program." target="_blank" rel="noopener">+1 (604) 719 &middot; 7918</a></span>
        <span class="sub">Mon&ndash;Fri &middot; 9:00&ndash;18:00 PT &middot; replies within 4 business hours</span>
      </div>
      <div class="cell">
        <span class="lbl">Email</span>
        <span class="val"><a href="mailto:hello@yarova.ca">hello@yarova.ca</a></span>
        <span class="sub">Send the syllabus, salary report, or alumni list to me.</span>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="foot">
  <div class="container foot-inner">
    <div>&copy; {today.getFullYear()} Yarova Inc. &middot; Langley, BC &middot; Operating since 2018</div>
    <div class="foot-links">
      <a href="#path">Curriculum</a>
      <a href="#track">Track record</a>
      <a href="/about">About</a>
      <a href="/blog">Blog</a>
      <a href="https://wa.me/16047197918" target="_blank" rel="noopener">WhatsApp</a>
      <a href="https://cal.com/yarova/fit-call" target="_blank" rel="noopener" data-cal-link="yarova/fit-call" data-cal-namespace="fit-call">Book a call</a>
    </div>
  </div>
</footer>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

  .foot { padding: 56px 0; border-top: 1px solid var(--border); background: var(--bg-secondary); }
  .foot-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px; font-size: 13px; color: var(--fg-2); }
  .foot a { color: var(--fg-2); text-decoration: none; }
  .foot a:hover { color: var(--fg-1); }
  .foot-links { display: flex; gap: 24px; flex-wrap: wrap; }
</style>

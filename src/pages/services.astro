---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Services — ${SITE_TITLE}`} description="Platform engineering consulting, AI automation projects, and engineering training from Yarova." />
  </head>
  <body>
    <Header />
    <main>
      <section class="page-header">
        <div class="page-inner">
          <h1>Services</h1>
          <p class="lead">
            We help teams build, scale, and automate their infrastructure. From Kubernetes architecture to AI-powered operations workflows.
          </p>
        </div>
      </section>

      <section class="offerings">
        <div class="page-inner">
          <div class="offerings-grid">
            <!-- Platform Engineering Consulting -->
            <div class="offering card">
              <div class="offering-header">
                <h2>Platform Engineering Consulting</h2>
                <div class="price">$200/hr <span class="price-unit">CAD</span></div>
              </div>
              <p class="offering-desc">Architecture, operations, and incident response for teams running container platforms at scale.</p>
              <h4 class="deliverables-label">Deliverables</h4>
              <ul>
                <li>Platform architecture review with written recommendations and action plan</li>
                <li>Kubernetes and OpenShift cluster design, namespace strategy, and RBAC policies</li>
                <li>Helm chart authoring, migration, and best-practice templates</li>
                <li>CI/CD pipeline optimization (GitHub Actions, ArgoCD, Tekton)</li>
                <li>GitOps workflow design and implementation</li>
                <li>Production readiness assessment with prioritized remediation roadmap</li>
                <li>Incident response support and post-mortem facilitation</li>
              </ul>
              <a href="mailto:hello@yarova.ca?subject=Consulting Inquiry" class="btn btn-primary">Get in Touch</a>
            </div>

            <!-- AI Automation -->
            <div class="offering card">
              <div class="offering-header">
                <h2>AI Automation</h2>
                <div class="price">from $2,000 <span class="price-unit">CAD / project</span></div>
              </div>
              <p class="offering-desc">Custom AI workflows and memory systems that compound your team's operational capacity.</p>
              <h4 class="deliverables-label">Deliverables</h4>
              <ul>
                <li>Custom Claude Code and MCP server integration for your engineering team</li>
                <li>AI memory systems (like Cortex) tailored to your infrastructure context</li>
                <li>Automated runbook generation from operational playbooks</li>
                <li>AI-assisted incident response workflows</li>
                <li>Operational procedure documentation with AI-powered search</li>
                <li>Training session for your team on using AI tooling effectively</li>
              </ul>
              <a href="mailto:hello@yarova.ca?subject=AI Automation Project" class="btn btn-primary">Start a Project</a>
            </div>

            <!-- Training -->
            <div class="offering card">
              <div class="offering-header">
                <h2>Training &amp; Workshops</h2>
                <div class="price">Coming soon</div>
              </div>
              <p class="offering-desc">Hands-on workshops and courses for engineering teams that want to level up their infrastructure practice.</p>
              <h4 class="deliverables-label">What to expect</h4>
              <ul>
                <li>Kubernetes fundamentals and advanced operations workshops</li>
                <li>Platform engineering best practices for growing teams</li>
                <li>AI-powered DevOps workflow training</li>
                <li>Custom curriculum tailored to your team's stack and goals</li>
                <li>Ongoing engineering blog with real-world patterns and tutorials</li>
              </ul>
              <a href="mailto:hello@yarova.ca?subject=Training Interest" class="btn btn-secondary">Join the Waitlist</a>
            </div>
          </div>
        </div>
      </section>

      <!-- How We Work -->
      <section class="process-section">
        <div class="page-inner">
          <h2>How we work</h2>
          <div class="process-grid">
            <div class="process-step">
              <div class="step-number">01</div>
              <h3>Discovery</h3>
              <p>We start by understanding your current infrastructure, pain points, and goals. A focused conversation to map the landscape.</p>
            </div>
            <div class="process-step">
              <div class="step-number">02</div>
              <h3>Architecture</h3>
              <p>We design a solution that fits your team's size, stack, and constraints. Clear diagrams, written recommendations, no black boxes.</p>
            </div>
            <div class="process-step">
              <div class="step-number">03</div>
              <h3>Implementation</h3>
              <p>We build alongside your team. Helm charts, pipelines, automation scripts, AI integrations -- whatever the project requires.</p>
            </div>
            <div class="process-step">
              <div class="step-number">04</div>
              <h3>Support</h3>
              <p>We stay available after handoff. Questions, incident support, and iteration as your platform evolves.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta-section">
        <div class="page-inner">
          <div class="cta-card">
            <h2>Ready to work together?</h2>
            <p>Tell us about your infrastructure challenges. We typically respond within one business day.</p>
            <a href="mailto:hello@yarova.ca" class="btn btn-primary btn-lg">hello@yarova.ca</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .page-inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Page Header */
  .page-header {
    padding: var(--space-20) 0 var(--space-12);
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 560px;
    line-height: var(--leading-normal);
  }

  /* Offerings */
  .offerings {
    padding-bottom: var(--space-16);
  }

  .offerings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }

  .offering {
    display: flex;
    flex-direction: column;
  }

  .offering-header {
    margin-bottom: var(--space-4);
  }

  .offering h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .price {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-amber);
  }

  .price-unit {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--text-tertiary);
  }

  .offering-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-6);
  }

  .deliverables-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: var(--space-4);
  }

  .offering ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8) 0;
    flex: 1;
  }

  .offering li {
    position: relative;
    padding-left: var(--space-6);
    margin-bottom: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }

  .offering li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-amber);
  }

  .offering .btn {
    align-self: flex-start;
  }

  /* Process */
  .process-section {
    padding: var(--space-16) 0;
  }

  .process-section h2 {
    margin-bottom: var(--space-10);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-8);
  }

  .process-step {
    padding: 0;
  }

  .step-number {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-amber);
    font-family: var(--font-mono);
    margin-bottom: var(--space-4);
  }

  .process-step h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .process-step p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* CTA */
  .cta-section {
    padding: var(--space-6) 0;
  }

  .cta-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-12) var(--space-8);
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .cta-card h2 {
    margin-bottom: var(--space-3);
  }

  .cta-card > p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 640px) {
    .page-header {
      padding: var(--space-12) 0 var(--space-8);
    }

    .page-header h1 {
      font-size: var(--text-3xl);
    }

    .offerings-grid {
      grid-template-columns: 1fr;
    }

    .process-grid {
      grid-template-columns: 1fr;
    }

    .cta-card {
      padding: var(--space-8) var(--space-6);
    }
  }
</style>

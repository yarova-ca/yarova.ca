---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Services — ${SITE_TITLE}`} description="Platform engineering consulting, DevOps coaching, and AI automation services." />
  </head>
  <body>
    <Header />
    <main>
      <section class="page-header">
        <div class="page-inner">
          <h1>Services</h1>
          <p class="lead">
            I help teams build, scale, and automate their infrastructure. From Kubernetes architecture to AI-powered DevOps workflows.
          </p>
        </div>
      </section>

      <section class="offerings">
        <div class="page-inner">
          <div class="offerings-grid">
            <!-- Platform Engineering -->
            <div class="offering card">
              <div class="offering-header">
                <h2>Platform Engineering Consulting</h2>
                <div class="price">$200/hr <span class="price-unit">CAD</span></div>
              </div>
              <ul>
                <li>Kubernetes and OpenShift architecture reviews</li>
                <li>Helm chart design and migration</li>
                <li>CI/CD pipeline optimization (GitHub Actions, ArgoCD, Tekton)</li>
                <li>Multi-cluster strategy and namespace design</li>
                <li>Production readiness assessments</li>
              </ul>
              <a href="mailto:rohith@yarova.ca?subject=Consulting Inquiry" class="btn btn-primary">Get in Touch</a>
            </div>

            <!-- DevOps Coaching -->
            <div class="offering card">
              <div class="offering-header">
                <h2>DevOps Coaching</h2>
                <div class="price">$150/hr <span class="price-unit">CAD</span></div>
              </div>
              <ul>
                <li>Career path to Staff / Principal / Distinguished Engineer</li>
                <li>System design interview preparation</li>
                <li>Building your own AI-powered DevOps workflow</li>
                <li>Resume and LinkedIn review for senior roles</li>
              </ul>
              <a href="mailto:rohith@yarova.ca?subject=Coaching Inquiry" class="btn btn-primary">Book a Session</a>
            </div>

            <!-- AI Automation -->
            <div class="offering card">
              <div class="offering-header">
                <h2>AI Automation Projects</h2>
                <div class="price">from $2,000 <span class="price-unit">CAD</span></div>
              </div>
              <ul>
                <li>Claude Code + MCP server integration for your team</li>
                <li>Custom memory systems (like Cortex) for your workflows</li>
                <li>Playbook development for operational procedures</li>
                <li>AI-assisted incident response and runbook automation</li>
              </ul>
              <a href="mailto:rohith@yarova.ca?subject=AI Automation Project" class="btn btn-primary">Start a Project</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Newsletter -->
      <section class="newsletter-section">
        <div class="page-inner">
          <div class="newsletter-card">
            <h2>The Infrastructure Newsletter</h2>
            <p>Weekly insights on platform engineering, DevOps, and AI automation. No spam, unsubscribe anytime.</p>
            <form class="newsletter-form" action="#" method="post">
              <input type="email" name="email" placeholder="your@email.com" required />
              <button type="submit" class="btn btn-primary">Subscribe</button>
            </form>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .page-inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Page Header */
  .page-header {
    padding: var(--space-20) 0 var(--space-12);
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 560px;
    line-height: var(--leading-normal);
  }

  /* Offerings */
  .offerings {
    padding-bottom: var(--space-16);
  }

  .offerings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }

  .offering {
    display: flex;
    flex-direction: column;
  }

  .offering-header {
    margin-bottom: var(--space-6);
  }

  .offering h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .price {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-amber);
  }

  .price-unit {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--text-tertiary);
  }

  .offering ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8) 0;
    flex: 1;
  }

  .offering li {
    position: relative;
    padding-left: var(--space-6);
    margin-bottom: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }

  .offering li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-amber);
  }

  .offering .btn {
    align-self: flex-start;
  }

  /* Newsletter */
  .newsletter-section {
    padding: var(--space-6) 0;
  }

  .newsletter-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-12) var(--space-8);
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .newsletter-card h2 {
    margin-bottom: var(--space-3);
  }

  .newsletter-card > p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .newsletter-form input {
    width: 260px;
    max-width: 100%;
  }

  @media (max-width: 640px) {
    .page-header {
      padding: var(--space-12) 0 var(--space-8);
    }

    .page-header h1 {
      font-size: var(--text-3xl);
    }

    .offerings-grid {
      grid-template-columns: 1fr;
    }

    .newsletter-card {
      padding: var(--space-8) var(--space-6);
    }
  }
</style>

---
import BaseHead from '../components/BaseHead.astro';
import CalEmbed from '../components/CalEmbed.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`About — ${SITE_TITLE}`}
      description="Yarova is a simulated remote workplace for DevOps and SRE engineers in Canada — built and run by Rohith Yadla, Solutions Architect with 10 years of production consulting."
    />
  </head>
  <body>
    <Header />
    <main>
      <article class="about">
        <div class="about-inner">

          <header class="about-header">
            <p class="about-tag">About Yarova</p>
            <h1>A real Canadian workplace.<br />Built for engineers who have never been hired in Canada.</h1>
          </header>

          <div class="about-content">

            <section>
              <p class="intro">
                Yarova is built on one thesis: the catch-22 is not your fault. You cannot get hired without Canadian experience, and you cannot get Canadian experience without being hired. Tutorials, certificates, and portfolio projects do not solve it. The only thing that does is doing the actual work, in a real squad, with a real Team Lead, on real infrastructure &mdash; with a real GitHub history a hiring manager can open and inspect.
              </p>
            </section>

            <section>
              <h2>What Yarova actually is</h2>
              <p>
                A simulated remote workplace for DevOps and SRE engineers. You join a squad of four. You report to a real Team Lead &mdash; a senior engineer who runs production at their day job. For eight weeks you ship real tickets to real repositories under the Yarova GitHub organization. You write Terraform. You open PRs. You get code-reviewed. You run incident drills. You demo on Fridays.
              </p>
              <p>
                When the batch ends, we walk you all the way to a stable Canadian job: resume rebuilt from your tickets, interview prep before every interview you book, background-check support, a day-one prep call, and probation check-ins at 30, 60, and 90 days. The finish line is not the offer &mdash; it is probation cleared.
              </p>
            </section>

            <section>
              <h2>What we believe</h2>
              <div class="values-grid">
                <div class="value">
                  <h3>The work has to be real</h3>
                  <p>If a hiring manager can tell it is a course portfolio, the program failed. Every commit lives on a public Yarova org. Every PR has a real reviewer. The only thing simulated is the employer relationship.</p>
                </div>
                <div class="value">
                  <h3>Four engineers per squad. Never more.</h3>
                  <p>A Team Lead can run a real standup, review every PR personally, and hold a weekly 1:1 with four engineers. Not with twelve. Lift the cap and the program becomes a course.</p>
                </div>
                <div class="value">
                  <h3>Honesty over polish</h3>
                  <p>We do not guarantee jobs. Anyone who does is lying. What we guarantee: if you finish a batch and do not land a stable role, you rejoin the next batch, free, and we keep going. No time cap.</p>
                </div>
                <div class="value">
                  <h3>Structure beats willpower</h3>
                  <p>You do not have to figure out what to do next. Every day has a standup, every ticket has acceptance criteria, every Friday has a demo. You know what comes next, always.</p>
                </div>
              </div>
            </section>

            <section>
              <h2>Who runs it</h2>
              <div class="founder-block">
                <div class="founder-info">
                  <h3>Rohith Yadla</h3>
                  <p class="founder-role">Founder &amp; Solutions Architect</p>
                  <p>
                    Yarova is built and run by Rohith Yadla &mdash; Solutions Architect with 10 years of production consulting across financial systems, enterprise cloud, and public-sector infrastructure.
                  </p>
                  <ul class="anchor-list">
                    <li>Morgan Stanley &mdash; financial systems consulting, trading infrastructure at scale</li>
                    <li>Salesforce &mdash; platform engineering consulting, enterprise Kubernetes and cloud</li>
                    <li>BC Government &mdash; Solutions Architect consulting, public sector infrastructure spanning 12+ ministries</li>
                  </ul>
                  <p>
                    On-call rotations. Systems handling money, traffic, and customer data. Real production pressure. Yarova is built from that experience &mdash; and the Team Leads we bring in are picked the same way.
                  </p>
                  <div class="founder-links">
                    <a href="https://github.com/yarova-ca" target="_blank" rel="noopener noreferrer">GitHub</a>
                    <a href="https://linkedin.com/in/rohithyadla" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                  </div>
                </div>
              </div>
            </section>

            <section class="connect">
              <h2>Talk to us</h2>
              <p>
                The first step is a 30-minute discovery call. We learn where you are, you learn what you are committing to. About a third of applicants get a yes; the rest get a clear, honest no with a path forward.
              </p>
              <a href="https://cal.com/yarova-fxqeea/discovery-call" target="_blank" rel="noopener"
                 data-cal-link="yarova-fxqeea/discovery-call"
                 data-cal-namespace="discovery-call"
                 data-cal-config='{"layout":"month_view"}'
                 class="btn btn-primary btn-lg">Book the discovery call</a>
            </section>

          </div>
        </div>
      </article>
    </main>
    <Footer />

    <CalEmbed namespace="discovery-call" />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .about-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .about-header {
    padding: var(--space-20) 0 var(--space-8);
  }

  .about-tag {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-amber-hover);
    margin-bottom: var(--space-4);
  }

  .about-header h1 {
    font-size: var(--text-4xl);
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .about-content section {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--border-color);
  }

  .about-content section:last-child {
    border-bottom: none;
  }

  .about-content h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-5);
  }

  .about-content p {
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }

  .about-content p:last-child {
    margin-bottom: 0;
  }

  .intro {
    font-size: var(--text-lg) !important;
    color: var(--text-primary) !important;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
    margin-top: var(--space-6);
  }

  .value {
    padding: var(--space-6);
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
  }

  .value h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-amber-hover);
    margin-bottom: var(--space-3);
  }

  .value p {
    font-size: var(--text-sm);
    margin: 0;
    line-height: 1.65;
  }

  .founder-block {
    margin-top: var(--space-6);
  }

  .founder-info h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
    color: var(--text-primary);
  }

  .founder-role {
    font-size: var(--text-sm) !important;
    color: var(--color-amber-hover) !important;
    font-weight: 500;
    margin-bottom: var(--space-5) !important;
  }

  .anchor-list {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0;
  }

  .anchor-list li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-2);
    padding-left: var(--space-4);
    position: relative;
  }

  .anchor-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-amber-hover);
    font-weight: 700;
  }

  .founder-links {
    display: flex;
    gap: var(--space-6);
    margin-top: var(--space-5);
  }

  .founder-links a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-amber-hover);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .founder-links a:hover {
    color: var(--color-amber-press);
  }

  .connect .btn {
    text-decoration: none;
    margin-top: var(--space-2);
  }

  @media (max-width: 640px) {
    .about-header {
      padding: var(--space-12) 0 var(--space-6);
    }

    .about-header h1 {
      font-size: var(--text-3xl);
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

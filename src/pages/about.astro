---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`About — ${SITE_TITLE}`} description="Yarova is a platform engineering company founded by Rohith Yadla. We make enterprise infrastructure as reliable as it is invisible." />
  </head>
  <body>
    <Header />
    <main>
      <article class="about">
        <div class="about-inner">
          <header class="about-header">
            <h1>About Yarova</h1>
          </header>

          <div class="about-content">
            <section>
              <p class="intro">
                Yarova is a platform engineering company founded with a simple thesis: infrastructure should accelerate your team, not slow it down. We design, build, and automate the systems that modern software depends on.
              </p>
            </section>

            <section>
              <h2>Our mission</h2>
              <p>
                Make enterprise infrastructure as reliable as it is invisible. When the platform works, teams ship faster, incidents drop, and engineers focus on the problems that matter. That is the outcome we optimize for.
              </p>
            </section>

            <section>
              <h2>Our values</h2>
              <div class="values-grid">
                <div class="value">
                  <h3>Precise</h3>
                  <p>We measure twice and cut once. Infrastructure work demands accuracy, and we bring disciplined attention to every configuration, pipeline, and deployment.</p>
                </div>
                <div class="value">
                  <h3>Generous</h3>
                  <p>We share what we learn. Through our blog, open-source contributions, and transparent consulting, we believe the best infrastructure knowledge should be accessible.</p>
                </div>
                <div class="value">
                  <h3>Grounded</h3>
                  <p>We stay close to the real work. No hand-waving architecture decks. We operate production systems and our recommendations come from lived experience.</p>
                </div>
                <div class="value">
                  <h3>Crafted</h3>
                  <p>We care about the details. Clean Helm charts, well-structured pipelines, thoughtful naming, clear documentation. Quality is not optional.</p>
                </div>
                <div class="value">
                  <h3>Human</h3>
                  <p>Technology serves people. We build systems that respect the humans who operate them -- clear error messages, sane defaults, and interfaces that reduce cognitive load.</p>
                </div>
              </div>
            </section>

            <section>
              <h2>The team</h2>
              <div class="team-member">
                <div class="team-info">
                  <h3>Rohith Yadla</h3>
                  <p class="team-role">Founder &amp; Principal Engineer</p>
                  <p>
                    Rohith is a platform engineer based in British Columbia, Canada. He designs and operates container platforms on OpenShift and Kubernetes for critical public services. His work spans CI/CD pipelines, GitOps workflows, observability, and multi-cluster operations at scale.
                  </p>
                  <p>
                    Before founding Yarova, Rohith built and maintained infrastructure supporting 14 production applications across multiple OpenShift clusters for the BC Government. He is an early adopter of AI-powered DevOps workflows and the creator of Cortex.
                  </p>
                  <div class="team-links">
                    <a href="https://github.com/AceYarova" target="_blank" rel="noopener noreferrer">GitHub</a>
                    <a href="https://linkedin.com/in/rohithyadla" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                    <a href="https://twitter.com/AceYarova" target="_blank" rel="noopener noreferrer">Twitter</a>
                  </div>
                </div>
              </div>
            </section>

            <section>
              <h2>Powered by Cortex</h2>
              <p>
                Cortex is our internal AI knowledge system -- a structured memory layer that captures infrastructure decisions, architecture patterns, and operational context across every engagement. It gives us the ability to maintain deep context across clusters, namespaces, and dozens of applications without losing signal in the noise.
              </p>
              <p>
                This is not just tooling we recommend to clients. It is the system we use every day to deliver faster, more reliable results. When you work with Yarova, you benefit from the compound intelligence that Cortex provides.
              </p>
            </section>

            <section class="connect">
              <h2>Get in touch</h2>
              <p>
                Interested in working together? We would love to hear about your infrastructure challenges.
              </p>
              <a href="mailto:hello@yarova.ca" class="btn btn-primary btn-lg">hello@yarova.ca</a>
            </section>
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .about-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .about-header {
    padding: var(--space-20) 0 var(--space-8);
  }

  .about-header h1 {
    font-size: var(--text-4xl);
    letter-spacing: -0.03em;
  }

  .about-content section {
    margin-bottom: var(--space-12);
  }

  .about-content h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-5);
  }

  .about-content p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }

  .intro {
    font-size: var(--text-lg) !important;
    color: var(--text-primary) !important;
    line-height: var(--leading-relaxed);
  }

  .about-content a {
    color: var(--color-amber);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .about-content a:hover {
    color: var(--color-amber-hover);
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-6);
  }

  .value {
    padding: var(--space-6);
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
  }

  .value h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-amber);
    margin-bottom: var(--space-3);
  }

  .value p {
    font-size: var(--text-sm);
    margin: 0;
    line-height: var(--leading-normal);
  }

  /* Team */
  .team-member {
    margin-top: var(--space-6);
  }

  .team-info h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
    color: var(--text-primary);
  }

  .team-role {
    font-size: var(--text-sm) !important;
    color: var(--color-amber) !important;
    font-weight: 500;
    margin-bottom: var(--space-5) !important;
  }

  .team-links {
    display: flex;
    gap: var(--space-6);
    margin-top: var(--space-2);
  }

  .team-links a {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  /* Connect */
  .connect {
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-color);
  }

  .connect .btn {
    text-decoration: none;
    margin-top: var(--space-2);
  }

  @media (max-width: 640px) {
    .about-header {
      padding: var(--space-12) 0 var(--space-6);
    }

    .about-header h1 {
      font-size: var(--text-3xl);
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

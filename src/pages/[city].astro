    <style>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      a { color: var(--color-amber-hover); text-decoration: none; }
      a:hover { color: var(--color-amber-press); }
      .skip { position: absolute; left: -9999px; top: 8px; background: var(--color-black); color: white; padding: 10px 14px; border-radius: 8px; font-size: 14px; z-index: 999; }
      .skip:focus { left: 12px; }

      .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
      .container.narrow { max-width: 720px; }
      .section { padding: 96px 0; border-top: 1px solid var(--border); }
      .section.alt { background: var(--bg-secondary); }

      h1, h2, h3 { font-family: var(--font-sans); margin: 0; color: var(--fg-1); letter-spacing: -.025em; }
      h1 { font-size: clamp(28px, 4.8vw, 62px); font-weight: 700; line-height: 1.06; letter-spacing: -.035em; }
      h2 { font-size: clamp(24px, 3.5vw, 44px); font-weight: 700; line-height: 1.1; }
      p { margin: 0; color: var(--fg-2); line-height: 1.65; }

      .btn { display: inline-flex; align-items: center; gap: 10px; padding: 14px 22px; border-radius: 999px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; line-height: 1; border: 1px solid transparent; cursor: pointer; transition: transform 120ms ease, background 150ms ease; text-decoration: none; }
      .btn-lg { padding: 18px 30px; font-size: 16px; }
      .btn-amber { background: var(--color-amber-hover); color: white !important; box-shadow: 0 8px 22px -10px rgba(217,119,6,.55); }
      .btn-amber:hover { background: var(--color-amber-press); color: white !important; transform: translateY(-1px); }
      .btn-ghost { background: transparent; color: var(--fg-1); border-color: var(--border); }
      .ghost-light { color: rgba(255,255,255,.8) !important; border-color: rgba(255,255,255,.2) !important; }
      .btn .arrow { transition: transform 180ms ease; display: inline-block; }
      .btn:hover .arrow { transform: translateX(3px); }

      .sec-label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
      .sec-label::before { content: ""; width: 20px; height: 1px; background: var(--color-amber-hover); }

      /* Hero */
      .hero { padding: 80px 0 72px; }
      .eyebrow { font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); margin-bottom: 32px; display: flex; align-items: center; gap: 10px; }
      .dot-green { width: 8px; height: 8px; border-radius: 50%; background: #10B981; box-shadow: 0 0 0 3px rgba(16,185,129,.2); flex-shrink: 0; }
      .hero h1 .acc { color: var(--color-amber-hover); }
      .hero-sub { font-size: 19px; color: var(--fg-2); margin-top: 28px; max-width: 620px; line-height: 1.6; }
      .actions { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
      .fine { font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; color: var(--fg-3); margin-top: 14px; }

      /* City body prose */
      .city-body { margin-top: 32px; }
      .city-body p { font-size: 16px; color: var(--fg-2); line-height: 1.7; margin-bottom: 18px; }
      .city-body strong { color: var(--fg-1); font-weight: 600; }
      .city-body blockquote { margin: 24px 0; padding: 20px 24px; background: var(--color-black); color: rgba(255,255,255,.9); border-radius: 10px; font-size: 17px; font-weight: 600; font-family: var(--font-mono); line-height: 1.4; border: none; font-style: normal; }

      /* How It Works */
      .how-grid { margin-top: 44px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
      .how-item { padding: 26px 22px; background: var(--bg-primary); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); display: flex; gap: 14px; }
      .how-item:nth-child(3n) { border-right: none; }
      .how-item:nth-child(4), .how-item:nth-child(5), .how-item:nth-child(6) { border-bottom: none; }
      .how-item-final { background: var(--color-black); }
      .how-item-final .how-n { color: var(--color-amber); }
      .how-item-final .how-title { color: white; }
      .how-n { font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--color-amber-hover); padding-top: 2px; flex-shrink: 0; }
      .how-title { font-size: 14px; font-weight: 500; color: var(--fg-1); line-height: 1.5; }
      @media (max-width: 880px) { .how-grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 560px) { .how-grid { grid-template-columns: 1fr; } .how-item { border-right: none !important; border-bottom: 1px solid var(--border) !important; } .how-item:last-child { border-bottom: none !important; } }
      .how-meta { margin-top: 28px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .how-meta-item { padding: 22px; background: var(--bg-secondary); border-radius: 12px; border: 1px solid var(--border); }
      .how-meta-label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; margin-bottom: 8px; }
      .how-meta-val { font-size: 14px; color: var(--fg-2); line-height: 1.6; }
      @media (max-width: 640px) { .how-meta { grid-template-columns: 1fr; } }

      /* Tracks */
      .tracks-grid { margin-top: 44px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .track-card { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 14px; padding: 28px; }
      .track-tag { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; margin-bottom: 10px; }
      .track-desc { font-size: 15px; font-weight: 500; color: var(--fg-1); margin-bottom: 18px; line-height: 1.5; }
      .track-owns-label { font-size: 11px; font-weight: 600; color: var(--fg-3); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 8px; }
      .track-card ul { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; }
      .track-card ul li { font-size: 13px; color: var(--fg-2); padding-left: 16px; position: relative; line-height: 1.5; }
      .track-card ul li::before { content: "→"; position: absolute; left: 0; color: var(--color-amber-hover); font-size: 12px; }
      .track-stack { font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); letter-spacing: .06em; padding-top: 14px; border-top: 1px solid var(--border); }
      @media (max-width: 700px) { .tracks-grid { grid-template-columns: 1fr; } }

      /* Salary table */
      .salary-table { margin-top: 36px; width: 100%; border-collapse: collapse; font-size: 14px; }
      .salary-table th { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .12em; color: var(--fg-3); padding: 10px 12px; border-bottom: 2px solid var(--border); text-align: left; }
      .salary-table td { padding: 12px; border-bottom: 1px solid var(--border); color: var(--fg-1); }
      .salary-table td:first-child { font-weight: 500; }
      .salary-table td:not(:first-child) { font-family: var(--font-mono); font-size: 13px; color: var(--color-amber-hover); font-weight: 600; }
      .salary-source { font-size: 12px; color: var(--fg-3); margin-top: 14px; line-height: 1.5; }
      .roi-strip { display: flex; align-items: center; gap: 16px; margin-top: 28px; padding: 20px 24px; background: var(--color-black); border-radius: 12px; flex-wrap: wrap; }
      .roi-strip span { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,.6); }
      .roi-strip strong { color: white; font-size: 15px; }
      .roi-arrow { color: rgba(255,255,255,.25) !important; font-size: 16px !important; }

      /* Pricing */
      .price-card { margin-top: 36px; background: var(--color-black); border-radius: 18px; padding: 44px; position: relative; overflow: hidden; }
      .price-card::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at top right, rgba(217,119,6,.15), transparent 60%); pointer-events: none; }
      .price-top { position: relative; margin-bottom: 32px; }
      .price-num { font-size: clamp(44px, 7vw, 66px); font-weight: 700; color: white; letter-spacing: -.04em; line-height: 1; }
      .price-num .ccy { font-size: 20px; color: rgba(255,255,255,.5); font-weight: 500; letter-spacing: 0; }
      .price-when { font-size: 13px; color: rgba(255,255,255,.4); margin-top: 8px; font-family: var(--font-mono); }
      .price-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; position: relative; }
      .price-col-label { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber); font-weight: 600; margin-bottom: 12px; }
      .price-col-label-neg { color: rgba(255,255,255,.35); }
      .price-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
      .price-list li { font-size: 14px; color: rgba(255,255,255,.8); padding-left: 20px; position: relative; }
      .price-list li::before { content: "✓"; position: absolute; left: 0; color: var(--color-amber); font-weight: 700; }
      .price-list-neg li { color: rgba(255,255,255,.35); }
      .price-list-neg li::before { content: "—"; color: rgba(255,255,255,.18); }
      @media (max-width: 560px) { .price-cols { grid-template-columns: 1fr; } }
      .price-cta { width: 100%; justify-content: center; position: relative; }

      /* FAQ */
      .faq { margin-top: 40px; }
      .faq details { border-bottom: 1px solid var(--border); padding: 20px 0; }
      .faq details summary { display: flex; justify-content: space-between; align-items: center; cursor: pointer; list-style: none; font-size: 16px; font-weight: 500; color: var(--fg-1); gap: 24px; }
      .faq details summary::-webkit-details-marker { display: none; }
      .glyph { font-family: var(--font-mono); font-size: 20px; color: var(--color-amber-hover); flex-shrink: 0; }
      .answer { padding-top: 14px; max-width: 620px; }
      .answer p { color: var(--fg-2); font-size: 14px; line-height: 1.7; margin-bottom: 10px; }
      .answer p:last-child { margin-bottom: 0; }

      /* Final CTA */
      .cta-final { background: var(--color-black); color: white; padding: 88px 0; }
      .cta-final h2 { color: white; }
      .cta-bullets { display: flex; flex-direction: column; gap: 6px; margin-top: 20px; }
      .cta-bullets span { font-size: 16px; color: rgba(255,255,255,.6); }
      .cta-contact { margin-top: 28px; display: flex; flex-direction: column; gap: 6px; }
      .cta-contact span { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,.35); }
      .cta-contact a { color: rgba(255,255,255,.6); }
      .cta-contact a:hover { color: white; }
    </style>

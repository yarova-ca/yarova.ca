---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import '../styles/enhancements.css';

const TITLE = 'Yarova Accounting — Personal, self-employed, and small-business tax filings, done by Canadian accountants.';
const DESC = 'Personal T1, self-employed, T2 corporate, and incorporation filings — at flat Canadian-CPA-reviewed fees. CRA audit response included. Pay only after the return is filed.';
const today = new Date();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={TITLE} description={DESC} />
    <script type="application/ld+json">
      {"@context":"https://schema.org","@graph":[{"@type":"AccountingService","@id":"https://yarova.ca/accounting/#svc","name":"Yarova Accounting","url":"https://yarova.ca/accounting","description":"Flat-fee Canadian tax preparation. Personal, self-employed, corporate, and incorporation filings.","areaServed":{"@type":"Country","name":"Canada"},"address":{"@type":"PostalAddress","addressLocality":"Langley","addressRegion":"BC","addressCountry":"CA"},"priceRange":"$149–$1,499 CAD"}]}
    </script>
  </head>
  <body data-screen-label="Yarova accounting">
    <a href="#hero" class="skip">Skip to content</a>

    <Header page="accounting" />

    <main id="hero">

      <!-- HERO -->
      <section class="hero" data-screen-label="01 Hero" data-rail="Hero">
        <div class="container">
          <div class="hero-eyebrow r-up">
            <span>Yarova Accounting &middot; Canadian tax filings</span>
            <span class="tag">A division of Yarova Inc.</span>
          </div>
          <h1 class="r-up">Personal taxes,<br />filed properly.<br />Small business,<br /><span class="acc">filed on time.</span></h1>
          <p class="hero-sub r-up d1">Yarova prepares <b>personal returns, self-employed filings, corporate T2s, and small-business incorporations</b> at flat Canadian fees &mdash; reviewed by a CPA-trained reviewer, e-filed direct to CRA, and backed by audit response at no extra charge. The same humans, year after year.</p>
          <div class="hero-actions r-up d2">
            <a href="#pricing" class="btn btn-amber btn-lg">See flat-fee pricing <span class="arrow">&rarr;</span></a>
            <a href="#process" class="btn btn-ghost btn-lg">How it works <span class="arrow">&rarr;</span></a>
          </div>
          <div class="hero-stamps r-up d3">
            <span class="stamp">Pay <b style="color:var(--color-amber-hover); margin:0 4px;">only after</b> the return is filed</span>
            <span class="stamp amber">CRA audit response &middot; included</span>
            <span class="stamp">CPA-reviewed &middot; NETFILE direct</span>
          </div>
          <div class="hero-meta r-up d4">
            <div class="cell"><span class="k">Personal &middot; T1</span><span class="v"><span data-count="149" data-prefix="$">$149</span> <small>flat</small></span></div>
            <div class="cell"><span class="k">Self-employed</span><span class="v"><span data-count="349" data-prefix="$">$349</span> <small>flat</small></span></div>
            <div class="cell"><span class="k">Small business &middot; T2</span><span class="v"><span data-count="999" data-prefix="$">$999</span> <small>flat</small></span></div>
            <div class="cell"><span class="k">Incorporation bundle</span><span class="v"><span data-count="1499" data-prefix="$">$1,499</span> <small>flat &middot; save $400</small></span></div>
          </div>
        </div>
      </section>

      <!-- LIVE COUNTER STRIP -->
      <section class="live-strip" data-screen-label="Live counter">
        <div class="container">
          <div class="ls-grid">
            <div class="ls-cell amber"><span class="v"><span data-count="1847">1,847</span></span><span class="k">Returns filed &middot; since 2022</span></div>
            <div class="ls-cell"><span class="v"><span data-count="312">312</span></span><span class="k">Small businesses &middot; active clients</span></div>
            <div class="ls-cell"><span class="v"><span data-count="0" data-prefix="$" data-suffix="K">$0K</span></span><span class="k">Audit-response fees billed &middot; ever</span></div>
            <div class="ls-cell"><span class="v"><span data-count="48">48</span><span class="ls-unit">hrs</span></span><span class="k">Average personal turnaround</span></div>
          </div>
        </div>
      </section>

      <!-- ANCHOR PRICING STRIP -->
      <section class="anchor-strip" data-screen-label="02 What it costs elsewhere">
        <div class="container">
          <div class="head r-up">
            <span class="eyebrow">&mdash; What you&rsquo;d pay elsewhere</span>
            <h3>Filing your taxes shouldn&rsquo;t cost more than what it saves you.</h3>
          </div>
          <div class="grid r-up d1">
            <div class="col">
              <span class="lbl">Walk-in tax shops</span>
              <span class="num">$80&ndash;$250</span>
              <span class="desc">Files what you hand them. No audit defense. No strategy. A new preparer every year who&rsquo;s never seen your file before.</span>
            </div>
            <div class="col">
              <span class="lbl">Big-firm CPA</span>
              <span class="num">$300&ndash;$500<small>/hr</small></span>
              <span class="desc">Hourly billing. Junior staff does the work, partner signs the bill. Personal returns become afterthoughts to the corporate clients who pay the rent.</span>
            </div>
            <div class="col">
              <span class="lbl">DIY tax software</span>
              <span class="num">$0&ndash;$60</span>
              <span class="desc">Files what you typed. Misses what you didn&rsquo;t know to type. No one picks up when CRA writes a reassessment letter two years later.</span>
            </div>
            <div class="col us">
              <span class="lbl">Yarova &middot; flat fee</span>
              <span class="num">$149&ndash;$1,499</span>
              <span class="desc">CPA-reviewed. NETFILE direct. Audit response included. Same human, same number, year after year. Pay only after the return is filed.</span>
            </div>
          </div>
          <div class="foot">&mdash; Market quotes reflect typical Canadian preparer pricing for comparable scope, 2024&ndash;2025.</div>
        </div>
      </section>

      <!-- PRICING — 4 TIERS -->
      <section id="pricing" class="section alt" data-screen-label="03 Pricing" data-rail="Pricing">
        <div class="container">
          <div class="sec-strip">
            <span class="num">01 / 06</span><span class="dot"></span><span>Pricing</span><span class="dot"></span><span>Four services. Four flat fees. Pick the one that matches your filing.</span>
          </div>
          <div class="pricing-head r-up">
            <h2>One flat fee per filing.<br />Same number next year.</h2>
            <p class="lead" style="margin-top:24px;">No hourly billing. No &ldquo;starts at.&rdquo; No upsells once we&rsquo;ve started. The number on the card is the number on your invoice &mdash; and we don&rsquo;t raise it on existing clients.</p>
          </div>

          <div class="pricing-4">
            <!-- PERSONAL -->
            <div class="price-card r-up" id="personal">
              <div>
                <div class="pc-label">Personal &middot; T1</div>
                <div class="who">Employees &middot; students &middot; newcomers &middot; retired &middot; most Canadians filing one tax slip set</div>
              </div>
              <div class="pc-price">
                <span class="price-num">$149</span>
                <span class="ccy">CAD</span>
              </div>
              <div class="market-context"><s>$80&ndash;$250 elsewhere</s> &middot; <b>flat $149.</b></div>
              <ul>
                <li>T1 federal + provincial filing</li>
                <li>All slips: T4, T5, T3, T4A, T2202, RRSP, TFSA, FHSA</li>
                <li>Credits optimized (climate, GST, CWB, medical)</li>
                <li>NETFILE direct to CRA, refund tracked</li>
                <li>CRA audit response &middot; included</li>
                <li>Filed in 48 hours from full docs</li>
              </ul>
              <div class="pc-actions">
                <a href="https://cal.com/yarova-fxqeea/tax-consult" target="_blank" rel="noopener" data-cal-link="yarova-fxqeea/tax-consult" data-cal-namespace="tax-consult" data-cal-config='{"layout":"month_view"}' class="btn btn-dark btn-lg" style="justify-content:center;">Book personal <span class="arrow">&rarr;</span></a>
                <span class="micro">15-min booking &middot; pay after filing</span>
              </div>
            </div>

            <!-- SELF-EMPLOYED -->
            <div class="price-card r-up d1" id="self-employed">
              <span class="badge">Most booked</span>
              <div>
                <div class="pc-label">Self-employed &middot; T1 + Business</div>
                <div class="who">Sole proprietors &middot; freelancers &middot; contractors &middot; rental owners &middot; gig income</div>
              </div>
              <div class="pc-price">
                <span class="price-num">$349</span>
                <span class="ccy">CAD</span>
              </div>
              <div class="market-context"><s>$300&ndash;$700 elsewhere</s> &middot; <b>flat $349.</b></div>
              <ul>
                <li>Everything in Personal &middot; T1</li>
                <li>T2125 business statement (revenue, expenses, CCA)</li>
                <li>T776 rental statement &middot; foreign-income T1135</li>
                <li>GST/HST filing if you&rsquo;re registered</li>
                <li>Quarterly tax-instalment plan in writing</li>
                <li>CRA audit response &middot; included</li>
                <li>Filed in 48&ndash;72 hours from full books</li>
              </ul>
              <div class="pc-actions">
                <a href="https://cal.com/yarova-fxqeea/tax-consult" target="_blank" rel="noopener" data-cal-link="yarova-fxqeea/tax-consult" data-cal-namespace="tax-consult" data-cal-config='{"layout":"month_view"}' class="btn btn-amber btn-lg" style="justify-content:center;">Book self-employed <span class="arrow">&rarr;</span></a>
                <span class="micro">20-min booking &middot; books reviewed first</span>
              </div>
            </div>

            <!-- SMALL BUSINESS T2 -->
            <div class="price-card featured r-up d2" id="business">
              <span class="badge green">Best value</span>
              <div>
                <div class="pc-label">Small Business &middot; T2</div>
                <div class="who">CCPCs &middot; incorporated consultants &middot; operating corporations with books in order</div>
              </div>
              <div class="pc-price">
                <span class="price-num">$999</span>
                <span class="ccy">CAD</span>
              </div>
              <div class="market-context"><s>$1,200&ndash;$2,500 elsewhere</s> &middot; <b>flat $999.</b></div>
              <ul>
                <li>T2 corporate return (federal + provincial)</li>
                <li>GIFI financial statements from your books</li>
                <li>GST/HST quarterly or annual filing</li>
                <li>T4 / T4A / T5 slip preparation</li>
                <li>Salary-vs-dividend plan in writing</li>
                <li>CRA audit response &middot; included</li>
                <li>Filed in 5&ndash;7 business days from clean books</li>
              </ul>
              <div class="pc-actions">
                <a href="https://cal.com/yarova-fxqeea/tax-consult" target="_blank" rel="noopener" data-cal-link="yarova-fxqeea/tax-consult" data-cal-namespace="tax-consult" data-cal-config='{"layout":"month_view"}' class="btn btn-amber btn-lg" style="justify-content:center;">Book T2 filing <span class="arrow">&rarr;</span></a>
                <span class="micro" style="color:var(--color-gray-400);">30-min booking &middot; fixed quote in writing</span>
              </div>
            </div>

            <!-- INCORPORATION BUNDLE -->
            <div class="price-card r-up d3" id="incorporation">
              <span class="badge">Save $400</span>
              <div>
                <div class="pc-label">Incorporation Bundle</div>
                <div class="who">New incorporators &middot; first-year corporations &middot; consultants moving from sole-prop to CCPC</div>
              </div>
              <div class="pc-price">
                <span class="price-num">$1,499</span>
                <span class="ccy">CAD</span>
              </div>
              <div class="market-context"><s>$1,899 unbundled</s> &middot; <b>save $400 when together.</b></div>
              <ul>
                <li>Federal or provincial incorporation</li>
                <li>Articles &middot; minute book &middot; NUANS &middot; registry</li>
                <li>First-year T2 corporate return</li>
                <li>GST/HST + payroll account setup</li>
                <li>Bookkeeping chart of accounts (QBO or Xero)</li>
                <li>Salary-vs-dividend plan &middot; year-one cashflow</li>
                <li>CRA audit response &middot; included</li>
              </ul>
              <div class="pc-actions">
                <a href="https://cal.com/yarova-fxqeea/tax-consult" target="_blank" rel="noopener" data-cal-link="yarova-fxqeea/tax-consult" data-cal-namespace="tax-consult" data-cal-config='{"layout":"month_view"}' class="btn btn-dark btn-lg" style="justify-content:center;">Book incorporation <span class="arrow">&rarr;</span></a>
                <span class="micro">45-min strategy call &middot; structure first</span>
              </div>
            </div>
          </div>

          <p style="margin-top:32px; text-align:center; font-size:13px; color:var(--fg-2); font-family:var(--font-mono); letter-spacing:.04em;">No subscription. No annual retainer. Pay only when you file. Same fee next year.</p>

          <!-- Audit defense callout -->
          <div class="audit-callout r-up">
            <div class="audit-icon">CRA</div>
            <div class="audit-body">
              <h4>If CRA writes back, Yarova writes back.</h4>
              <p>Every flat fee includes audit-response support for the life of the return &mdash; letters, document submissions, follow-up calls. No hourly billing. No &ldquo;representation upcharge.&rdquo; That&rsquo;s what flat means.</p>
            </div>
            <span class="audit-pill">Included</span>
          </div>
        </div>
      </section>

      <!-- TRUST -->
      <section id="trust" class="section" data-screen-label="04 Trust" data-rail="Why Yarova">
        <div class="container">
          <div class="sec-strip">
            <span class="num">02 / 06</span><span class="dot"></span><span>Why Yarova</span><span class="dot"></span><span>What flat-fee actually buys you</span>
          </div>
          <h2 class="r-up">Reviewed by a human.<br />Filed with CRA. Defended at audit.</h2>
          <p class="lead r-up d1" style="margin-top:24px;">Software files what you tell it. Yarova files what&rsquo;s actually in your situation &mdash; and stays on the line if CRA asks questions later.</p>

          <div class="trust-grid">
            <div class="trust-card r-up"><div class="tc-icon">CPA</div><h4>CPA-trained reviewer on every return</h4><p>Every filing is prepared and reviewed by a Yarova reviewer trained under a Canadian CPA. Not outsourced. Not run through a bot.</p></div>
            <div class="trust-card r-up d1"><div class="tc-icon">CRA</div><h4>CRA audit response included</h4><p>If CRA reviews or audits a return Yarova prepared, we respond on your behalf &mdash; at no extra charge. Most firms bill $150&ndash;$400/hr for this.</p></div>
            <div class="trust-card r-up d2"><div class="tc-icon">SEC</div><h4>Canadian-server document handling</h4><p>Encrypted upload. Documents on Canadian servers. Kept only as long as CRA retention requires, then purged.</p></div>
            <div class="trust-card r-up"><div class="tc-icon">FIX</div><h4>We catch what software misses</h4><p>FHSA in your first year. RRSP carry-forward you didn&rsquo;t track. CCB and GST/HST credits you forgot. The credits a checkbox-driven flow won&rsquo;t surface.</p></div>
            <div class="trust-card r-up d1"><div class="tc-icon">$$$</div><h4>Salary-vs-dividend strategy for incorporators</h4><p>For business clients: a written remuneration plan tuned to your bracket. The owner-manager decision software can&rsquo;t make for you.</p></div>
            <div class="trust-card r-up d2"><div class="tc-icon">&infin;</div><h4>Same flat fee, year after year</h4><p>$149 personal. $349 self-employed. $999 T2. $1,499 incorporation. Same number on next year&rsquo;s invoice. No tier creep.</p></div>
          </div>
        </div>
      </section>

      <!-- PROCESS -->
      <section id="process" class="section alt" data-screen-label="05 Process" data-rail="Process">
        <div class="container">
          <div class="sec-strip">
            <span class="num">03 / 06</span><span class="dot"></span><span>Process</span><span class="dot"></span><span>Four steps. No surprises.</span>
          </div>
          <h2 class="r-up">From booking to NETFILE confirmation,<br />in four steps.</h2>
          <p class="lead r-up d1" style="margin-top:24px;">No mystery email chains. No &ldquo;we&rsquo;ll get back to you.&rdquo; Each step has a clear owner, a clear handoff, and a clear next date.</p>

          <div class="process">
            <div class="proc-step r-up"><span class="proc-num">01 &middot; Book</span><h3>Book your filing</h3><p>15&ndash;45 minutes depending on scope. We confirm what you&rsquo;re filing, send the document checklist, and lock the flat fee in writing.</p><span class="when">Same day</span></div>
            <div class="proc-step r-up d1"><span class="proc-num">02 &middot; Upload</span><h3>Upload through secure intake</h3><p>One encrypted link. T-slips, expenses, books, statements &mdash; everything on the checklist. Completeness confirmed within 4 business hours.</p><span class="when">Day 1&ndash;2</span></div>
            <div class="proc-step r-up d2"><span class="proc-num">03 &middot; Review</span><h3>CPA review &amp; strategy call</h3><p>Return prepared, credit-optimization pass, then a 15-minute walkthrough so you understand every line before we file.</p><span class="when">48 hrs &middot; 5&ndash;7 days</span></div>
            <div class="proc-step r-up d3"><span class="proc-num">04 &middot; NETFILE</span><h3>E-file &amp; confirmation</h3><p>Filed direct to CRA. Confirmation number, assessment tracker, calendar reminder 30 days out for the assessment review.</p><span class="when">Same day as approval</span></div>
          </div>
        </div>
      </section>

      <!-- TESTIMONIALS -->
      <section class="section" data-screen-label="06 Testimonials" data-rail="Clients">
        <div class="container">
          <div class="sec-strip">
            <span class="num">04 / 06</span><span class="dot"></span><span>Clients</span><span class="dot"></span><span>From newcomers to incorporated consultants</span>
          </div>
          <h2 class="r-up">The numbers people walk away with.</h2>
          <p class="lead r-up d1" style="margin-top:24px;">Real returns, recent filings. Names abbreviated for privacy; full case studies available on request after a discovery call.</p>

          <div class="testis">
            <div class="testi r-up">
              <div class="saved"><b>+$1,200</b><span>larger refund vs prior preparer</span></div>
              <div class="quote">Switched from a walk-in chain. Same employment slips, two rental properties, one freelance contract &mdash; they wanted $340 and missed FHSA entirely. Yarova caught it, filed in two days, and the refund grew by $1,200.</div>
              <div class="meta-row"><span><b>Personal &middot; $149</b></span><span>2-day turnaround</span></div>
              <div class="who"><div class="avatar" style="background:#1F3A5F;">SK</div><div><div class="name">Sara K.</div><div class="role">Marketing manager &middot; Toronto</div></div></div>
            </div>
            <div class="testi r-up d1">
              <div class="saved"><b>$0</b><span>audit fee &mdash; included in flat fee</span></div>
              <div class="quote">CRA reassessed my self-employment return from three years ago. My old preparer wanted $1,800 to respond. Yarova handled the entire correspondence at no charge &mdash; that&rsquo;s not an upsell, it&rsquo;s actually included.</div>
              <div class="meta-row"><span><b>Self-employed &middot; $349</b></span><span>Reassessment resolved</span></div>
              <div class="who"><div class="avatar" style="background:#3A4A1B;">RT</div><div><div class="name">Robert T.</div><div class="role">Independent contractor &middot; Ottawa</div></div></div>
            </div>
            <div class="testi r-up d2">
              <div class="saved"><b>$4,200</b><span>tax saved on salary-vs-dividend plan</span></div>
              <div class="quote">Incorporated my consulting practice with Yarova. Lawyer quote was $1,400 just for incorporation, then $1,800 for the T2. Yarova bundled both for $1,499 and the remuneration plan saved me $4,200 in personal tax.</div>
              <div class="meta-row"><span><b>Incorporation &middot; $1,499</b></span><span>Bundled</span></div>
              <div class="who"><div class="avatar" style="background:#5B3A1B;">DH</div><div><div class="name">Dev H.</div><div class="role">Software consultant &middot; Calgary</div></div></div>
            </div>
            <div class="testi r-up">
              <div class="saved"><b>&minus;$1,500</b><span>cheaper than old accountant</span></div>
              <div class="quote">Two-person Shopify store, growing fast. Old accountant charged $2,200 a year and never picked up the phone. Yarova: $999, monthly check-ins included, GST/HST quick-method election we didn&rsquo;t even know existed.</div>
              <div class="meta-row"><span><b>T2 &middot; $999</b></span><span>Quick-method GST</span></div>
              <div class="who"><div class="avatar" style="background:#0F4F46;">JM</div><div><div class="name">Janelle M.</div><div class="role">E-commerce founder &middot; Mississauga</div></div></div>
            </div>
            <div class="testi r-up d1">
              <div class="saved"><b>T1135</b><span>handled at flat fee, no surcharge</span></div>
              <div class="quote">Newcomer, first Canadian filing. I&rsquo;d tried DIY software and got stuck on T1135 because I have property back home. Yarova handled it without flinching, walked me through every line, and the bill was the price on the website.</div>
              <div class="meta-row"><span><b>Personal &middot; $149</b></span><span>48 hours</span></div>
              <div class="who"><div class="avatar" style="background:#5B1B4F;">AM</div><div><div class="name">Adaeze M.</div><div class="role">Healthcare worker &middot; Vancouver</div></div></div>
            </div>
            <div class="testi r-up d2">
              <div class="saved"><b>Same fee</b><span>year three of flat $149 &middot; no tier creep</span></div>
              <div class="quote">Retired, two pensions, one rental, foreign dividend slips. Other firms quoted $400+ for &ldquo;complexity.&rdquo; Yarova: $149 &mdash; same complexity, same flat fee. They don&rsquo;t pretend retirement income is exotic.</div>
              <div class="meta-row"><span><b>Personal &middot; $149</b></span><span>Pension splitting</span></div>
              <div class="who"><div class="avatar" style="background:#1B3A4F;">EW</div><div><div class="name">Eleanor W.</div><div class="role">Retired &middot; Victoria</div></div></div>
            </div>
          </div>
        </div>
      </section>

      <!-- RISK REVERSAL -->
      <section class="acct-risk" data-screen-label="07 Promise" data-rail="Promise">
        <div class="container">
          <div class="risk-grid">
            <div class="r-up">
              <div class="sec-strip" style="color:rgba(255,255,255,.5);">
                <span class="num" style="color:var(--color-amber);">&mdash; Our promise</span>
              </div>
              <h2>Pay only when<br />the return is <em>filed.</em></h2>
              <p>We prepare your return. We walk you through every line. You approve. <em>Then</em> we invoice. If you&rsquo;re not satisfied with the work before NETFILE, you don&rsquo;t pay &mdash; and we hand back every document you uploaded.</p>
            </div>
            <div class="seal r-up d1">
              <div class="seal-badge">GUARANTEED &middot; SINCE 2022</div>
              <div class="stamp">The Yarova Accounting guarantee</div>
              <h3>Flat fee.<br />Filed by humans.<br />Defended at audit.</h3>
              <div class="three">
                <div class="row"><span class="n">01</span><span><b>No filing, no fee</b><span>Pay only after the return is approved by you and ready for CRA.</span></span></div>
                <div class="row"><span class="n">02</span><span><b>Flat means flat</b><span>$149 / $349 / $999 / $1,499. Year after year. No tier creep.</span></span></div>
                <div class="row"><span class="n">03</span><span><b>Audit response included</b><span>If CRA writes, Yarova writes back &mdash; at no additional charge, ever.</span></span></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq" class="section alt" data-screen-label="08 FAQ" data-rail="FAQ">
        <div class="container">
          <div class="sec-strip">
            <span class="num">05 / 06</span><span class="dot"></span><span>Common questions</span><span class="dot"></span><span>Answers, not promises</span>
          </div>
          <h2 class="r-up">Questions you should ask<br /><em>before committing.</em></h2>

          <div class="faq r-up d1">
            <details open>

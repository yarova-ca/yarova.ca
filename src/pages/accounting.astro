      @media (max-width: 720px) { .ls-grid { grid-template-columns: repeat(2, 1fr); } }

      /* Pricing cards */
      .pricing-head { margin-bottom: 48px; }
      .pricing-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
      .price-card { background: white; border: 1px solid var(--border); border-radius: 16px; padding: 28px 24px; display: flex; flex-direction: column; gap: 18px; position: relative; transition: transform 280ms cubic-bezier(.22,.7,.18,1), box-shadow 280ms ease, border-color 280ms ease; }
      .price-card:hover { transform: translateY(-3px); box-shadow: 0 1px 2px rgba(0,0,0,.04), 0 18px 36px -22px rgba(0,0,0,.22); border-color: var(--border-hover); }
      .price-card.featured { background: var(--color-black); color: var(--color-gray-300); border-color: var(--color-black); }
      .price-card.featured h3, .price-card.featured h4, .price-card.featured .price-num, .price-card.featured .ccy { color: white; }
      .badge { position: absolute; top: -10px; right: 18px; background: var(--color-amber-hover); color: white; padding: 4px 10px; border-radius: 999px; font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .14em; font-weight: 600; }
      .badge.green { background: #10B981; }
      .pc-label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); }
      .price-card.featured .pc-label { color: var(--color-amber); }
      .who { font-size: 12px; color: var(--fg-3); margin-top: 4px; line-height: 1.5; }
      .price-card.featured .who { color: var(--color-gray-400); }
      .pc-price { display: flex; align-items: baseline; gap: 6px; padding: 4px 0; }
      .price-num { font-size: 52px; font-weight: 700; letter-spacing: -.04em; color: var(--fg-1); line-height: 1; }
      .price-card.featured .price-num { color: white; }
      .ccy { font-family: var(--font-mono); font-size: 12px; color: var(--fg-3); }
      .price-card.featured .ccy { color: var(--color-gray-400); }
      .market-context { font-size: 12px; color: var(--fg-3); }
      .market-context s { text-decoration: line-through; }
      .market-context b { color: var(--color-amber-hover); font-weight: 600; }
      .price-card.featured .market-context { color: var(--color-gray-400); }
      .price-card.featured .market-context b { color: var(--color-amber); }
      .price-card ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; font-size: 13px; line-height: 1.45; color: var(--fg-2); }
      .price-card.featured ul { color: var(--color-gray-300); }
      .price-card ul li { display: flex; gap: 8px; }
      .price-card ul li::before { content: "✓"; color: var(--color-amber-hover); flex-shrink: 0; font-weight: 700; }
      .price-card.featured ul li::before { color: var(--color-amber); }
      .pc-actions { margin-top: auto; display: flex; flex-direction: column; gap: 8px; padding-top: 8px; }
      .micro { font-size: 11px; color: var(--fg-3); text-align: center; line-height: 1.4; }
      .price-card.featured .micro { color: var(--color-gray-400); }
      @media (max-width: 1080px) { .pricing-4 { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 560px) { .pricing-4 { grid-template-columns: 1fr; } }

      /* Audit callout */
      .audit-callout { display: grid; grid-template-columns: 80px 1fr auto; gap: 20px; align-items: center; padding: 24px 28px; background: var(--color-black); color: white; border-radius: 16px; margin-top: 32px; }
      .audit-icon { width: 64px; height: 64px; border-radius: 14px; background: rgba(217,119,6,.18); border: 1px solid rgba(217,119,6,.3); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: .14em; color: var(--color-amber); }
      .audit-body h4 { color: white; font-size: 19px; margin-bottom: 4px; letter-spacing: -.01em; }
      .audit-body p { color: var(--color-gray-400); font-size: 14px; line-height: 1.5; max-width: 540px; }
      .audit-pill { padding: 8px 14px; background: var(--color-amber-hover); color: white; border-radius: 999px; font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; font-weight: 600; white-space: nowrap; }
      @media (max-width: 720px) { .audit-callout { grid-template-columns: 1fr; } }

      /* Trust */
      .trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
      .trust-card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 28px 24px; transition: transform 240ms ease, border-color 240ms ease; }
      .trust-card:hover { transform: translateY(-3px); border-color: var(--border-hover); }
      .tc-icon { width: 36px; height: 36px; border-radius: 8px; background: var(--bg-secondary); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: var(--color-amber-hover); margin-bottom: 16px; }
      .trust-card h4 { font-size: 16px; margin-bottom: 8px; }
      .trust-card p { font-size: 14px; color: var(--fg-2); line-height: 1.55; }
      @media (max-width: 880px) { .trust-grid { grid-template-columns: 1fr; } }

      /* Process */
      .process { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 56px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .proc-step { padding: 32px 28px; border-right: 1px solid var(--border); display: flex; flex-direction: column; gap: 12px; }
      .proc-step:last-child { border-right: none; }
      .proc-num { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; }
      .proc-step h3 { font-size: 18px; }
      .proc-step p { font-size: 14px; color: var(--fg-2); }
      .when { font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); margin-top: auto; padding-top: 8px; }
      @media (max-width: 880px) { .process { grid-template-columns: 1fr; } .proc-step { border-right: none; border-bottom: 1px solid var(--border); } .proc-step:last-child { border-bottom: none; } }

      /* Testimonials */
      .testis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
      .testi { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 28px; display: flex; flex-direction: column; gap: 16px; transition: transform 260ms ease, border-color 260ms ease; }
      .testi:hover { transform: translateY(-3px); border-color: var(--border-hover); }
      .testi .quote { font-size: 15px; line-height: 1.55; color: var(--fg-1); font-weight: 500; }
      .testi .quote::before { content: "\201C"; font-size: 32px; line-height: 0; vertical-align: -10px; color: var(--color-amber-hover); margin-right: 4px; }
      .saved { display: inline-flex; align-items: baseline; gap: 6px; padding: 8px 14px; background: rgba(217,119,6,.08); border-radius: 8px; font-family: var(--font-mono); font-size: 12px; }
      .saved b { font-size: 20px; color: var(--color-amber-hover); font-weight: 700; letter-spacing: -.01em; }
      .saved span { color: var(--fg-2); }
      .testi .meta-row { display: flex; gap: 14px; font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); text-transform: uppercase; letter-spacing: .08em; }
      .testi .meta-row b { color: var(--color-amber-hover); font-weight: 600; }
      .testi .who { display: flex; align-items: center; gap: 12px; padding-top: 14px; border-top: 1px solid var(--border); margin-top: auto; }
      .testi .avatar { width: 40px; height: 40px; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; flex-shrink: 0; }
      .testi .name { font-size: 13px; font-weight: 600; color: var(--fg-1); }
      .testi .role { font-size: 12px; color: var(--fg-3); margin-top: 2px; font-family: var(--font-mono); letter-spacing: .02em; }
      @media (max-width: 980px) { .testis { grid-template-columns: 1fr; } }

      /* Risk reversal */
      .acct-risk { background: var(--color-black); color: white; padding: 80px 0; }
      .acct-risk h2 { color: white; }
      .risk-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 64px; align-items: center; }
      .acct-risk p { color: var(--color-gray-300); font-size: 17px; line-height: 1.65; max-width: 560px; margin-top: 24px; }
      .acct-risk em { color: var(--color-amber); font-style: normal; font-weight: 700; }
      .seal { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); border-radius: 16px; padding: 36px; }
      .seal-badge { display: inline-block; border: 1.5px solid var(--color-amber); color: var(--color-amber); font-family: var(--font-mono); font-size: 10px; letter-spacing: .2em; padding: 4px 12px; border-radius: 4px; margin-bottom: 14px; text-transform: uppercase; }
      .stamp { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber); margin-bottom: 16px; }
      .seal h3 { color: white; font-size: 22px; line-height: 1.3; margin-bottom: 24px; }
      .three { display: flex; flex-direction: column; gap: 14px; }
      .row { display: grid; grid-template-columns: 32px 1fr; gap: 14px; padding: 14px 0; border-top: 1px solid rgba(255,255,255,.1); }
      .row:first-child { border-top: none; padding-top: 0; }
      .n { color: var(--color-amber); font-family: var(--font-mono); font-size: 14px; font-weight: 600; }
      .row b { color: white; display: block; font-size: 14px; margin-bottom: 4px; }
      .row span span { color: var(--color-gray-400); font-size: 13px; line-height: 1.5; }
      @media (max-width: 880px) { .risk-grid { grid-template-columns: 1fr; gap: 48px; } }

      /* FAQ */
      .faq { max-width: 880px; margin-top: 32px; }
      .faq details { border-bottom: 1px solid var(--border); padding: 22px 0; }
      .faq details summary { display: flex; justify-content: space-between; align-items: center; cursor: pointer; list-style: none; font-size: 17px; font-weight: 500; color: var(--fg-1); gap: 24px; }
      .faq details summary::-webkit-details-marker { display: none; }
      .faq summary .glyph { font-family: var(--font-mono); font-size: 22px; color: var(--color-amber-hover); flex-shrink: 0; }
      .faq .answer { padding-top: 16px; max-width: 720px; }
      .faq .answer p { margin-bottom: 12px; color: var(--fg-2); line-height: 1.7; font-size: 14px; }
      .faq .answer p:last-child { margin-bottom: 0; }

      /* Accounting footer */
      .acct-footer { background: var(--color-black); color: var(--color-gray-400); padding: 80px 0 40px; }
      .af-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 64px; }
      .af-grid .brand { color: white; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px; }
      .af-grid .brand .y { width: 26px; height: 26px; display: inline-flex; align-items: center; justify-content: center; background: var(--color-amber-hover); color: white; border-radius: 6px; font-weight: 700; font-size: 14px; }
      .af-tag { margin-top: 12px; font-size: 14px; line-height: 1.6; max-width: 320px; color: var(--color-gray-400); }
      .acct-footer h5 { color: white; font-size: 13px; text-transform: uppercase; letter-spacing: .14em; font-family: var(--font-mono); margin-bottom: 18px; }
      .acct-footer ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
      .acct-footer a { color: var(--color-gray-400); font-size: 14px; }
      .acct-footer a:hover { color: white; }
      .af-legal { padding-top: 32px; border-top: 1px solid rgba(255,255,255,.08); display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--color-gray-500); flex-wrap: wrap; gap: 16px; }
      @media (max-width: 880px) { .af-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
    </style>
  </body>
</html>

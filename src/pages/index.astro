---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/enhancements.css';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script type="application/ld+json">
      {"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://yarova.ca/#org","name":"Yarova","url":"https://yarova.ca","description":"Canadian IT placement consultancy. Operating since 2018.","foundingDate":"2018-09-01","address":{"@type":"PostalAddress","addressLocality":"Langley","addressRegion":"BC","addressCountry":"CA"}},{"@type":"Course","name":"Yarova Placement Program","description":"Interactive IT placement program covering the full request path from first principles. Includes resume, interview, and background-check support until placement.","provider":{"@id":"https://yarova.ca/#org"},"offers":{"@type":"Offer","price":"1500","priceCurrency":"CAD","availability":"https://schema.org/LimitedAvailability"}}]}
    </script>
  </head>
  <body data-screen-label="Yarova placement home">
    <a class="skip" href="#main">Skip to content</a>

    <Header />

    <!-- Reading preferences (ND-friendly) -->
    <div class="prefs" id="prefs">
      <button class="prefs-toggle" id="prefsToggle" aria-expanded="false" aria-controls="prefsPanel">Reading preferences</button>
      <div class="prefs-panel" id="prefsPanel" role="dialog" aria-label="Reading preferences">
        <h4>Reading preferences</h4>
        <p class="hint">Adjust the page to suit your reading style.</p>
        <div class="pref-row">
          <div>
            <div class="label">Wider spacing</div>
            <div class="desc">More breathing room between sections.</div>
          </div>
          <div class="switch" data-mode="spacious" role="switch" tabindex="0" aria-checked="false"></div>
        </div>
        <div class="pref-row">
          <div>
            <div class="label">Larger text</div>
            <div class="desc">Bump body text by ~15%.</div>
          </div>
          <div class="switch" data-mode="larger" role="switch" tabindex="0" aria-checked="false"></div>
        </div>
      </div>
    </div>

    <main id="main">

      <!-- HERO -->
      <section id="hero" class="hero" data-screen-label="01 Hero" data-rail="Hero">
        <div class="hero-glow"></div>
        <div class="container">
          <div class="hero-eyebrow">
            <span>Yarova &middot; IT Job Placement Consultancy &middot; Canada</span>
            <span class="tag">Operating since 2018</span>
          </div>
          <h1 class="r-up">AI doesn't replace engineers.<br />It replaces engineers who don't<br /><span class="acc">understand the system.</span></h1>
          <p class="hero-sub r-up d1">Every IT job left is the same job: <strong>understand the full request path well enough to direct an AI tool that doesn't.</strong> Yarova teaches those concepts from first principles, then places you into a Canadian engineering role &mdash; interviews, background checks, offer review &mdash; until the offer is in your hand. <strong>91% of graduates placed within 6 months.</strong> One price. One outcome.</p>
          <div class="hero-actions r-up d2">
            <a href="#cta-final" class="btn btn-amber btn-lg magnetic">Schedule a 30-minute fit call <span class="arrow">&rarr;</span></a>
            <a href="#track" class="btn btn-ghost btn-lg">See the track record <span class="arrow">&rarr;</span></a>
          </div>
          <div class="hero-meta r-up d3">
            <div class="cell"><span class="k">Placed within 6 months</span><span class="v"><span data-count="91" data-suffix="%">0</span><small>of all graduates</small></span></div>
            <div class="cell"><span class="k">Operating since</span><span class="v">2018<small>8 cohorts run</small></span></div>
            <div class="cell"><span class="k">Investment</span><span class="v"><span data-count="1500" data-prefix="$">$0</span><small>CAD &middot; one-time</small></span></div>
            <div class="cell"><span class="k">Guarantee</span><span class="v">Until placed<small>re-enroll free</small></span></div>
          </div>
        </div>
      </section>

      <!-- AUTHORITY STRIP -->
      <section class="authority" data-screen-label="02 Authority" data-rail="Track record">
        <div class="container">
          <div class="row">
            <div class="cell"><div class="num" data-count="91" data-suffix="%">0%</div><div class="lbl">Placed within 6 months</div></div>
            <div class="cell"><div class="num" data-count="312">0</div><div class="lbl">Engineers placed since 2018</div></div>
            <div class="cell"><div class="num" data-count="8">0</div><div class="lbl">Cohorts run &middot; 9th open now</div></div>
            <div class="cell"><div class="num" data-count="96" data-prefix="$" data-suffix="k">$0</div><div class="lbl">Median first-year base, CAD</div></div>
          </div>
        </div>
      </section>

      <!-- ANCHOR PRICING STRIP -->
      <section class="anchor-strip" data-screen-label="02b Anchor">
        <div class="container">
          <div class="head r-up">
            <span class="eyebrow">&mdash; What the alternatives actually cost</span>
            <h3>The hidden bill of every other path into engineering.</h3>
          </div>
          <div class="grid r-up d1">
            <div class="col"><span class="lbl">University CS degree</span><span class="num">$40K&ndash;$120K</span><span class="desc">Four years. Heavy on theory, light on the request path. You graduate without ever touching DNS, observability, or a real on-call rotation.</span></div>
            <div class="col"><span class="lbl">Coding bootcamp</span><span class="num">$12K&ndash;$22K</span><span class="desc">12 weeks of framework drills. Placement help is a Slack channel and a r&eacute;sum&eacute; template. Outcome statistics fall apart under scrutiny.</span></div>
            <div class="col"><span class="lbl">Self-study, no placement</span><span class="num">$0 + 2 yrs</span><span class="desc">Free in dollars, expensive in months. No structure, no review, no one returning hiring-manager calls on your behalf. Most people stall in month 5.</span></div>
            <div class="col us"><span class="lbl">Yarova &middot; flat fee</span><span class="num">$1,500</span><span class="desc">Full curriculum + weekly live cohort + 1:1 placement work until offer. 91% placed inside 6 months. Re-enroll free if you&rsquo;re not.</span></div>
          </div>
          <div class="foot">&mdash; Comparisons drawn from publicly listed Canadian program fees and median timelines, 2024&ndash;2025.</div>
        </div>
      </section>

      <!-- WHAT WE ENSURE -->
      <section id="ensure" class="section" data-screen-label="03 What we ensure" data-rail="Concepts">
        <div class="container">
          <div class="sec-strip">
            <span class="num">01 / 09</span><span class="dot"></span><span>What we ensure</span><span class="dot"></span><span>90 sec read</span>
          </div>
          <h2 class="r-up">AI tools amplify engineers who<br />understand the system.<br /><em>They expose engineers who don&rsquo;t.</em></h2>
          <p class="lead r-up d1" style="margin-top: 24px;">An AI tool that writes a database migration is useless to someone who can&rsquo;t read the migration. An AI that generates a Kubernetes manifest is a liability to someone who can&rsquo;t audit it. The hiring market has noticed: every role left is being rewritten around engineers who can <strong>direct</strong> AI tools &mdash; who know what the right answer looks like, where the tool is wrong, and how the system fits together end-to-end. Yarova teaches those concepts from first principles. Then we make three promises and keep every one of them.</p>

          <div class="ensure-grid">
            <div class="ensure-card">
              <span class="num">01 &middot; Concepts</span>
              <h3>You understand every layer.</h3>
              <div class="body">DNS, networking, operating systems, services, caching, databases, observability, security, cloud &mdash; the full request path, taught from first principles. Tools change every two years; principles don&rsquo;t. Master the principles and any tool &mdash; including the AI ones &mdash; becomes a multiplier instead of a black box.</div>
              <div class="why"><b>Why it matters</b> &mdash; You can&rsquo;t direct what you don&rsquo;t understand. Concepts first. Tools second. The order is the entire job.</div>
            </div>
            <div class="ensure-card">
              <span class="num">02 &middot; Real practice</span>
              <h3>You work through real systems.</h3>
              <div class="body">Interactive live cohort sessions every week. We trace a request through every layer of a real production system, together. You break things. You fix them. You explain trade-offs out loud. By the time you interview, you&rsquo;ve been inside the work &mdash; not watching it from outside.</div>
              <div class="why"><b>Why it matters</b> &mdash; Hiring managers can tell in 90 seconds whether you&rsquo;ve actually touched the system. We make sure you have.</div>
            </div>
            <div class="ensure-card">
              <span class="num">03 &middot; Placement</span>
              <h3>You get hired &mdash; or stay free.</h3>
              <div class="body">Resume rebuilt for recruiter search. LinkedIn tuned for inbound. Pre-interview rehearsals for every loop you book. Background-check coordination. Offer-letter walkthrough. Day-1 plan. Day-90 follow-up.</div>
              <div class="why"><b>The guarantee</b> &mdash; If you finish the program and aren&rsquo;t placed, you re-enroll free. Every cohort. Until your offer arrives.</div>
            </div>
          </div>

          <div class="cost-box">
            <div class="lead-lbl">The cost of waiting</div>
            <div class="stmt">Median Canadian IT base is <b>$96,000</b>. Every month spent applying alone &mdash; without the concept foundation that interviews actually test for &mdash; costs roughly <b>$8,000</b> in lost income. Six months of solo job-searching costs <b>thirty-two times the program fee</b>. The fee buys back the months.</div>
          </div>
        </div>
      </section>

      <!-- REQUEST PATH / CURRICULUM -->
      <section id="path" class="section alt" data-screen-label="04 Curriculum" data-rail="Curriculum">
        <div class="container">
          <div class="sec-strip">
            <span class="num">02 / 09</span><span class="dot"></span><span>The full request path</span><span class="dot"></span><span>3 min read</span>
          </div>
          <h2>Every layer a request passes through &mdash;<br />covered from <em>first principles.</em></h2>
          <p class="lead" style="margin-top: 24px;">A web request travels seven layers from a user&rsquo;s browser to your database and back. Most courses teach one layer in isolation. Yarova teaches the path. Once you can reason about the whole journey, any tool at any layer is approachable.</p>

          <div class="path">
            <div class="path-grid">
              <div class="path-node"><span class="ord">01</span><span class="layer">DNS &amp; Edge</span><span class="topic">resolution &middot; CDN &middot; TLS</span></div>
              <div class="path-node"><span class="ord">02</span><span class="layer">Load Balancer</span><span class="topic">L4 &middot; L7 &middot; routing</span></div>
              <div class="path-node"><span class="ord">03</span><span class="layer">Application</span><span class="topic">services &middot; APIs &middot; auth</span></div>
              <div class="path-node"><span class="ord">04</span><span class="layer">Cache</span><span class="topic">memory &middot; CDN &middot; invalidation</span></div>
              <div class="path-node"><span class="ord">05</span><span class="layer">Data</span><span class="topic">SQL &middot; NoSQL &middot; queues</span></div>
              <div class="path-node"><span class="ord">06</span><span class="layer">Storage</span><span class="topic">object &middot; block &middot; backup</span></div>
              <div class="path-node"><span class="ord">07</span><span class="layer">Observe</span><span class="topic">metrics &middot; logs &middot; traces</span></div>
            </div>

            <div class="layers-detail">
              <div class="layer-row"><span class="n">01</span><span class="t">Foundations</span><span class="d">Linux internals, TCP/IP, DNS, HTTP, TLS. The vocabulary every interview opens with.</span></div>
              <div class="layer-row"><span class="n">02</span><span class="t">Networking</span><span class="d">Routing, load balancing, service discovery, CDN behavior. How traffic actually finds a process.</span></div>
              <div class="layer-row"><span class="n">03</span><span class="t">Applications &amp; APIs</span><span class="d">Services, REST/gRPC, authentication, idempotency, retries, timeouts. The shape of every real service.</span></div>
              <div class="layer-row"><span class="n">04</span><span class="t">Caching</span><span class="d">In-process, distributed, CDN. Invalidation, consistency, hot-key problems. The hardest thing in computer science.</span></div>
              <div class="layer-row"><span class="n">05</span><span class="t">Data</span><span class="d">SQL vs NoSQL, transactions, replication, sharding, queues, streams. Trade-offs explained, not memorized.</span></div>
              <div class="layer-row"><span class="n">06</span><span class="t">Distributed Systems</span><span class="d">Consensus, clocks, CAP, partial failure. The mental model every senior interview requires.</span></div>
              <div class="layer-row"><span class="n">07</span><span class="t">Observability</span><span class="d">Metrics, logs, traces, SLOs, alert routing. Knowing what broke and where, fast.</span></div>
              <div class="layer-row"><span class="n">08</span><span class="t">Security</span><span class="d">Authn/authz, secrets, supply chain, threat modeling. The questions every regulated employer asks.</span></div>
              <div class="layer-row"><span class="n">09</span><span class="t">Cloud Platforms</span><span class="d">AWS &middot; GCP &middot; Azure. Networking, IAM, managed services. Same principles, different keywords.</span></div>
              <div class="layer-row"><span class="n">10</span><span class="t">Reliability</span><span class="d">Postmortems, runbooks, on-call, incident response. The work that earns senior trust.</span></div>
              <div class="layer-row"><span class="n">11</span><span class="t">CI/CD &amp; Delivery</span><span class="d">Build, test, deploy, progressive rollout. The pipeline every engineering org runs.</span></div>
              <div class="layer-row"><span class="n">12</span><span class="t">Interview readiness</span><span class="d">System design, live coding, salary negotiation, offer review. The last mile every program skips.</span></div>
            </div>
          </div>
        </div>
      </section>

      <!-- TRACK RECORD -->
      <section id="track" class="section" data-screen-label="05 Track record" data-rail="Outcomes">
        <div class="container">
          <div class="sec-strip">
            <span class="num">03 / 09</span><span class="dot"></span><span>Track record &middot; since 2018</span><span class="dot"></span><span>Public numbers</span>
          </div>
          <h2 class="r-up">Eight cohorts.<br /><em>Three hundred and twelve</em> placements.</h2>
          <p class="lead r-up d1" style="margin-top: 24px;">Every cohort run since 2018, with the same numbers an investor would ask for. Median time-to-offer has dropped every year as the curriculum matured. The 9th cohort opens with the strongest pipeline yet.</p>

          <div class="cohort-bar r-up d1" style="margin-top:32px;">
            <div class="left">
              <span class="lbl">Cohort 9 &middot; enrollment closing</span>
              <div class="track"><span class="fill" style="width: 88%;"></span></div>
            </div>
            <span class="seats"><b>22 of 25</b> seats filled &middot; 3 remaining</span>
          </div>

          <table class="track-table">
            <thead>
              <tr>
                <th>Year</th>
                <th>Cohort</th>
                <th class="hide-sm">Enrolled</th>
                <th>Placed</th>
                <th>Within 6 mo</th>
                <th class="hide-sm">Median offer</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="yr">2018</td><td>C1</td><td class="hide-sm">12</td><td>10</td><td class="pct">75%</td><td class="hide-sm">$78k</td></tr>
              <tr><td class="yr">2019</td><td>C2</td><td class="hide-sm">22</td><td>19</td><td class="pct">82%</td><td class="hide-sm">$82k</td></tr>
              <tr><td class="yr">2020</td><td>C3</td><td class="hide-sm">28</td><td>24</td><td class="pct">86%</td><td class="hide-sm">$84k</td></tr>
              <tr><td class="yr">2021</td><td>C4</td><td class="hide-sm">34</td><td>31</td><td class="pct">88%</td><td class="hide-sm">$92k</td></tr>
              <tr><td class="yr">2022</td><td>C5</td><td class="hide-sm">42</td><td>39</td><td class="pct">93%</td><td class="hide-sm">$98k</td></tr>
              <tr><td class="yr">2023</td><td>C6</td><td class="hide-sm">48</td><td>45</td><td class="pct">94%</td><td class="hide-sm">$102k</td></tr>
              <tr><td class="yr">2024</td><td>C7</td><td class="hide-sm">56</td><td>52</td><td class="pct">93%</td><td class="hide-sm">$104k</td></tr>
              <tr><td class="yr">2025</td><td>C8</td><td class="hide-sm">62</td><td>58</td><td class="pct">94%</td><td class="hide-sm">$108k</td></tr>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="2">Cumulative &middot; since 2018</td>
                <td class="hide-sm">304</td>
                <td>278</td>
                <td class="pct">91% avg</td>
                <td class="hide-sm">$96k median</td>
              </tr>
            </tfoot>
          </table>
          <p class="track-foot">Placements are Canadian engineering roles only. <em>Placed</em> means signed offer in hand; <em>within 6 months</em> measures from program start. C9 is in progress &mdash; 3 seats remaining. Numbers are audited annually and made available under NDA on the fit call.</p>
        </div>
      </section>

      <!-- TESTIMONIALS -->
      <section class="section alt" data-screen-label="06 Voices">
        <div class="container">
          <div class="sec-strip">
            <span class="num">04 / 09</span><span class="dot"></span><span>What graduates say</span><span class="dot"></span><span>Six voices &middot; all Canadian roles</span>
          </div>
          <h2>The people who came through.<br />The roles they walked into.</h2>

          <div class="testis">
            <div class="testi">
              <div class="quote">CS degree and 80 rejections. Eight months into Yarova, three offers. Every interviewer opened my GitHub before the call &mdash; the merged PRs did the talking.</div>
              <div class="meta-row"><span><b>C5</b></span><span>8 months</span><span>$102k base</span></div>
              <div class="who"><div class="avatar" style="background:#1F3A5F;">PA</div><div><div class="name">Priya A.</div><div class="role">SRE &middot; fintech, Toronto</div></div></div>
            </div>
            <div class="testi">
              <div class="quote">I came from sysadmin work. Yarova teaches you to think in systems, not in tickets. The reference body is the book I wish I&rsquo;d had ten years ago.</div>
              <div class="meta-row"><span><b>C3</b></span><span>6 months</span><span>$118k base</span></div>
              <div class="who"><div class="avatar" style="background:#5B3A1B;">MK</div><div><div class="name">Marcus K.</div><div class="role">Platform engineer &middot; SaaS, Vancouver</div></div></div>
            </div>
            <div class="testi">
              <div class="quote">Background-check stage usually breaks me. Yarova handled the references, the verification, the offer-letter line review. I showed up and said yes.</div>
              <div class="meta-row"><span><b>C7</b></span><span>5 months</span><span>$88k base</span></div>
              <div class="who"><div class="avatar" style="background:#0F4F46;">AS</div><div><div class="name">Aisha S.</div><div class="role">DevOps engineer &middot; gov, Victoria</div></div></div>
            </div>
            <div class="testi">
              <div class="quote">High-school teacher pivoting at 38. Yarova didn&rsquo;t blink. Built for people whose calendar doesn&rsquo;t bend &mdash; async review, weekly anchor, no graded humiliation.</div>
              <div class="meta-row"><span><b>C6</b></span><span>11 months</span><span>$84k base</span></div>
              <div class="who"><div class="avatar" style="background:#3A4A1B;">DT</div><div><div class="name">Daniela T.</div><div class="role">Junior DevOps &middot; SaaS, Calgary</div></div></div>
            </div>
            <div class="testi">
              <div class="quote">Newcomer to Canada with foreign credentials nobody read. Yarova rebuilt my LinkedIn so recruiters found me in week three. The GitHub said senior; the title caught up.</div>
              <div class="meta-row"><span><b>C4</b></span><span>9 months</span><span>$96k base</span></div>
              <div class="who"><div class="avatar" style="background:#5B1B4F;">RN</div><div><div class="name">Ravi N.</div><div class="role">Cloud engineer &middot; enterprise, Mississauga</div></div></div>
            </div>
            <div class="testi">
              <div class="quote">Mid-career, ten years in. Came for interview prep, stayed for the depth. Negotiated $22k above the original offer using the salary calibration call alone.</div>
              <div class="meta-row"><span><b>C7</b></span><span>4 months</span><span>$142k base</span></div>
              <div class="who"><div class="avatar" style="background:#1B3A4F;">JL</div><div><div class="name">James L.</div><div class="role">Senior SRE &middot; marketplace, Ottawa</div></div></div>
            </div>
          </div>
        </div>
      </section>

      <!-- CURRICULUM PHASES -->
      <section class="section" data-screen-label="07 Curriculum phases">
        <div class="container">
          <div class="sec-strip">
            <span class="num">05 / 09</span><span class="dot"></span><span>Curriculum</span><span class="dot"></span><span>8 phases &middot; 6 to 12 months</span>
          </div>
          <h2>One coherent path.<br />Each phase compounds on the last.</h2>
          <p class="lead" style="margin-top: 24px;">Self-paced. Weekly live cohort session anchors the rhythm. Async code review on every submission.</p>

          <div class="phases">
            <div class="phase-row"><div class="num">01</div><div class="title">Foundations</div><div class="skills">Linux internals &middot; TCP/IP &middot; DNS &middot; text protocols &middot; git as a system</div><div class="count">4<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">02</div><div class="title">Containers &amp; Orchestration</div><div class="skills">OCI &middot; namespaces &middot; multi-stage builds &middot; Kubernetes &middot; CNI/CSI &middot; RBAC</div><div class="count">6<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">03</div><div class="title">Services &amp; Data</div><div class="skills">REST &middot; gRPC &middot; queues &middot; SQL &middot; NoSQL &middot; caching &middot; idempotency</div><div class="count">5<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">04</div><div class="title">Observability &amp; Reliability</div><div class="skills">Prometheus &middot; OpenTelemetry &middot; SLOs &middot; alert routing &middot; postmortems</div><div class="count">4<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">05</div><div class="title">CI/CD &amp; Supply Chain</div><div class="skills">Pipelines &middot; progressive delivery &middot; SLSA &middot; SBOM &middot; signing</div><div class="count">3<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">06</div><div class="title">Infrastructure as Code</div><div class="skills">Terraform &middot; module design &middot; state &middot; drift &middot; Well-Architected pillars</div><div class="count">3<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">07</div><div class="title">Security &amp; Cloud</div><div class="skills">OWASP &middot; IAM &middot; secrets &middot; zero-trust &middot; multi-region design</div><div class="count">3<small>weeks</small></div></div>
            <div class="phase-row"><div class="num">08</div><div class="title">Interview &amp; Placement</div><div class="skills">System design &middot; live coding &middot; resume rebuild &middot; salary calibration &middot; offer review</div><div class="count">2<small>weeks</small></div></div>
          </div>
        </div>
      </section>

      <!-- RISK REVERSAL -->
      <section class="risk" data-screen-label="08 Promise">
        <div class="container">
          <div class="risk-grid">
            <div>
              <div class="sec-strip" style="color:rgba(255,255,255,.5);">
                <span class="num" style="color:var(--color-amber);">&mdash; OUR PROMISE</span>
              </div>
              <h2>We don&rsquo;t stop until<br />you have <em>an offer.</em></h2>
              <p>Complete the program. If you don&rsquo;t have a Canadian IT offer in hand by your cohort&rsquo;s close &mdash; rejoin the next one. Then the one after. <strong style="color:white;">Free, forever, until you&rsquo;re hired.</strong> Yarova carries the placement risk. You carry the work.</p>
            </div>
            <div class="seal">
              <div class="stamp">The Yarova guarantee</div>
              <h3>One price.<br />Stay until you&rsquo;re placed.</h3>
              <div class="three">
                <div class="row"><span class="n">01</span><span><b>Re-enroll free</b>Every subsequent cohort, until offer in hand.</span></div>

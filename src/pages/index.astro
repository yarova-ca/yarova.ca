---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import FounderPhoto from '../assets/blog-placeholder-about.jpg'; /* TODO: Replace with actual founder portrait (1024×1024) before launch */
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- Sticky bottom CTA — mobile only, appears after 50% scroll -->
    <div id="sticky-cta" class="sticky-cta" aria-hidden="true">
      <button type="button"
        data-cal-link="yarova-fxqeea/discovery-call"
        data-cal-origin="https://cal.com"
        class="sticky-cta-link">
        Schedule a fit call &rarr;
      </button>
      <button id="sticky-dismiss" class="sticky-dismiss" aria-label="Dismiss">&times;</button>
    </div>

    <!-- Desktop progress indicator — right rail, 1280px+ only -->
    <nav class="progress-nav" aria-label="Page sections">
      {[
        { id: 'hero',     label: 'Hero' },
        { id: 'trust',    label: 'Trust' },
        { id: 'inspect',  label: 'Work' },
        { id: 'fit',      label: 'Fit' },
        { id: 'roles',    label: 'Roles' },
        { id: 'build',    label: 'Build' },
        { id: 'includes', label: 'Includes' },
        { id: 'flow',     label: 'Flow' },
        { id: 'founder',  label: 'Founder' },
        { id: 'schedule', label: 'Next' },
      ].map((s, i) => (
        <a href={`#${s.id}`} class="progress-dot" data-progress-index={i} aria-label={s.label} title={s.label}></a>
      ))}
    </nav>

    <main>

      <!-- ─── SECTION 1 — HERO ─────────────────────────────────── -->
      <section id="hero" class="s-hero" data-section data-section-index="0">
        <div class="inner">
          <p class="hero-tag">A CONSULTANCY, NOT A BOOTCAMP</p>
          <h1>
            An IT placement consultancy for the AI era.<br />
            You need a DevOps or SRE job in Canada. We get you there.
          </h1>
          <p class="hero-mirror">
            You've applied. The interviews haven't converted.<br />
            Or you haven't gotten interviews at all.<br />
            The problem is depth — and that's exactly what we fix.
          </p>
          <button type="button"
            data-cal-link="yarova-fxqeea/discovery-call"
            data-cal-origin="https://cal.com"
            class="btn btn-primary btn-lg">
            Schedule a fit call
          </button>
          <p class="cadence">Monthly cohorts &middot; 40 seats &middot; Applications close end of month</p>
        </div>
      </section>

      <!-- ─── SECTION 2 — TRUST STRIP ──────────────────────────── -->
      <section id="trust" class="s-trust" data-section data-section-index="1">
        <div class="inner trust-inner">
          <!-- TODO: Replace FounderPhoto with actual founder portrait (1024×1024) before launch -->
          <Image
            src={FounderPhoto}
            alt="Rohith Yadla, Founder of Yarova"
            width={80}
            height={80}
            class="trust-avatar"
          />
          <div class="trust-content">
            <p class="trust-name">Built and run by Rohith Yadla</p>
            <p class="trust-title">Solutions Architect &middot; 10 years production consulting</p>
            <ul class="trust-anchors">
              <li>Morgan Stanley &mdash; financial systems consulting, trading infrastructure at scale</li>
              <li>Salesforce &mdash; platform engineering consulting, enterprise Kubernetes and cloud</li>
              <li>BC Government &mdash; Solutions Architect consulting, public sector infrastructure across 12+ ministries</li>
            </ul>
            <a href="#founder" class="trust-link">Read the founder&rsquo;s full background &darr;</a>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 3 — INSPECT THE WORK ─────────────────────── -->
      <section id="inspect" class="s-inspect s-padded" data-section data-section-index="2">
        <div class="inner">
          <h2>Inspect the Work</h2>
          <p class="section-sub">Read the actual material before you decide. Three real artifacts from the program.</p>

          <div class="tab-bar" role="tablist">
            <button class="tab-btn active" data-tab="tab-chapter" role="tab" aria-selected="true" aria-controls="tab-chapter">A Chapter</button>
            <button class="tab-btn" data-tab="tab-ticket" role="tab" aria-selected="false" aria-controls="tab-ticket">A Ticket</button>
            <button class="tab-btn" data-tab="tab-question" role="tab" aria-selected="false" aria-controls="tab-question">An Interview Question</button>
          </div>

          <div id="tab-chapter" class="tab-panel" role="tabpanel">
            <div class="artifact-block">
              <p class="artifact-label">Chapter 4 &mdash; Observability: What You Measure Is What You Operate</p>
              <div class="artifact-content">
                <p class="artifact-section-head">4.1 &mdash; Why observability is not monitoring</p>
                <p>Monitoring answers: "Is it up?"<br />
                Observability answers: "Why is it behaving this way?"</p>
                <p>The difference matters in production.<br />
                A dashboard that shows 200 green checks<br />
                can coexist with a 15% error rate<br />
                on a path you never thought to monitor.</p>
                <p>Observability is built on three signals:</p>
                <ul class="artifact-list">
                  <li><strong>Metrics</strong> &mdash; time-series numbers: request rate, latency, error rate, saturation</li>
                  <li><strong>Logs</strong> &mdash; structured events with context: who, what, when, with what result</li>
                  <li><strong>Traces</strong> &mdash; the path a single request took through every service it touched</li>
                </ul>
                <p>In this chapter:</p>
                <ul class="artifact-list">
                  <li>You instrument the viro-services stack with Prometheus metrics</li>
                  <li>You configure log shipping from pods to a central collector</li>
                  <li>You write alerting rules tied to your SLOs, not just thresholds</li>
                  <li>You build the Grafana dashboard your on-call rotation will actually use</li>
                </ul>
                <p class="artifact-footer">The chapter has 11 sections and 4 hands-on tickets. Each ticket ships to your GitHub history.</p>
              </div>
            </div>
          </div>

          <div id="tab-ticket" class="tab-panel" hidden role="tabpanel">
            <div class="artifact-block">
              <p class="artifact-label">VIRO-018 &middot; Configure Prometheus alerting rules</p>
              <div class="artifact-content">
                <p class="artifact-meta">Phase 4 &mdash; Observability &middot; Repo: viro-tooling &middot; Estimated: 3 hours</p>
                <p class="artifact-section-head">Objective</p>
                <p>Deploy PrometheusRule manifests for the viro-services workload.<br />
                Rules must be validated, deployed, and visible in Alertmanager.</p>
                <p class="artifact-section-head">Acceptance criteria</p>
                <ul class="artifact-list checklist">
                  <li>PrometheusRule resource applied to viro-observability namespace</li>
                  <li>Three alerting rules active: HighErrorRate, PodCrashLooping, HighMemoryPressure</li>
                  <li>Rules pass <code>amtool check-rules</code> with zero errors</li>
                  <li>Alerts visible and correctly routed in Alertmanager UI</li>
                  <li>Screenshot of Alertmanager committed to ticket as completion evidence</li>
                </ul>
                <p class="artifact-section-head">Skills exercised</p>
                <p class="artifact-tags">Prometheus &middot; Kubernetes &middot; YAML &middot; PrometheusOperator CRDs &middot; amtool</p>
                <p class="artifact-footer">This ticket ships to your GitHub. A hiring manager can open it.</p>
              </div>
            </div>
          </div>

          <div id="tab-question" class="tab-panel" hidden role="tabpanel">
            <div class="artifact-block">
              <p class="artifact-label">Interview Question &mdash; Incident Response</p>
              <div class="artifact-content">
                <p class="artifact-section-head">The question</p>
                <blockquote class="interview-q">
                  "Your service is throwing 503s. You have 5 minutes before the incident commander calls you. Walk me through your first three moves."
                </blockquote>

                <p class="artifact-section-head answer-level junior">Junior answer</p>
                <p>Check if pods are running with <code>kubectl get pods</code>.<br />
                Check recent logs with <code>kubectl logs</code>.<br />
                Check if a deployment was pushed recently.</p>

                <p class="artifact-section-head answer-level senior">Senior answer</p>
                <p>Open Grafana. Check error rate and latency P99 for the affected service.<br />
                Check HPA status &mdash; are pods scaling but pending?<br />
                Check ArgoCD &mdash; any recent sync that changed the deployment?<br />
                Cross-check upstream dependencies &mdash; is the database or a downstream API degraded?<br />
                Prepare a 30-second status: error rate, duration, suspected cause, mitigation underway.</p>

                <p class="artifact-section-head answer-level fellow">Fellow answer</p>
                <p>Query Prometheus immediately for error budget burn rate.<br />
                If burn rate &gt; 14&times;, SLO breach is imminent &mdash; that changes escalation priority.<br />
                Correlate the error spike timestamp against deployment events, node events, and infrastructure changes.<br />
                While querying, open a parallel terminal &mdash; never block on one check.<br />
                When the incident commander calls: "Error rate at X%, started at T, likely correlated with [event],
                mitigation is [action], ETA to resolution [estimate]."</p>
                <p class="artifact-footer">The fellow never arrives to that call without a hypothesis.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 4 — WHO THIS IS FOR ──────────────────────── -->
      <section id="fit" class="s-fit s-padded s-alt" data-section data-section-index="3">
        <div class="inner">
          <h2>Who This Is For</h2>
          <p class="section-sub">About 70% of applicants fit one of these four. The rest have requirements the program can&rsquo;t address &mdash; that&rsquo;s what the discovery call is for.</p>
          <div class="profiles-grid">
            <div class="profile-card card">
              <h3>Already in Canada, time is short.</h3>
              <p>Generic certifications haven&rsquo;t produced interviews. You need a structured path with real GitHub artifacts hiring managers can inspect.</p>
            </div>
            <div class="profile-card card">
              <h3>Arriving in Canada within 6&ndash;12 months &mdash; or PGWP runway shrinking.</h3>
              <p>Program runs fully online. Start now, finish before authorization opens, land ready to interview.</p>
            </div>
            <div class="profile-card card">
              <h3>Switching from a non-technical career into IT.</h3>
              <p>You want DevOps or SRE specifically &mdash; not generic software engineer. You&rsquo;ve watched enough YouTube to know structure beats more videos.</p>
            </div>
            <div class="profile-card card">
              <h3>Already in IT, going senior.</h3>
              <p>Junior, sysadmin, QA, developer. You want depth: cloud, Kubernetes, observability, on-call. Not breadth.</p>
            </div>
          </div>
          <p class="profiles-footer">If none of these is you, the discovery call is the place to find out.</p>
        </div>
      </section>

      <!-- ─── SECTION 5 — ROLES YOU'LL BE READY FOR ────────────── -->
      <section id="roles" class="s-roles s-padded" data-section data-section-index="4">
        <div class="inner">
          <h2>Roles You&rsquo;ll Be Ready to Interview For</h2>
          <p class="section-sub">Canadian 2026 market. The program builds the GitHub portfolio, depth, and interview readiness these roles require.</p>
          <table class="roles-table">
            <thead>
              <tr>
                <th>Role</th>
                <th>2026 Base Salary (CAD)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>DevOps Engineer (Junior&ndash;Mid)</td>
                <td>$75,000 &ndash; $110,000</td>
              </tr>
              <tr>
                <td>Site Reliability Engineer I&ndash;II</td>
                <td>$90,000 &ndash; $130,000</td>
              </tr>
              <tr>
                <td>Site Reliability Engineer III / Senior</td>
                <td>$130,000 &ndash; $170,000</td>
              </tr>
              <tr>
                <td>Platform Engineer</td>
                <td>$110,000 &ndash; $155,000</td>
              </tr>
              <tr>
                <td>Cloud Engineer / Cloud Architect Assoc.</td>
                <td>$95,000 &ndash; $140,000</td>
              </tr>
            </tbody>
          </table>
          <p class="disclaimer">Canadian 2026 base-salary bands sourced from public job listings (LinkedIn, Indeed, Glassdoor). Yarova does not guarantee placement at any specific salary.</p>
        </div>
      </section>

      <!-- ─── SECTION 6 — THE FULL PICTURE ─────────────────────── -->
      <section id="build" class="s-build s-padded s-alt" data-section data-section-index="5">
        <div class="inner">
          <h2>The Full Picture</h2>
          <p class="section-sub">What you&rsquo;ll build &mdash; 33 tickets across 8 phases.</p>

          <div class="accordion-group">
            <details class="accordion">
              <summary>Phase 1 &mdash; Foundations <span class="ticket-count">4 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Linux fundamentals: filesystem, processes, networking from the terminal.</li>
                  <li>Git workflow used by real engineering teams &mdash; branches, PRs, rebasing.</li>
                  <li>Set up your development environment exactly as the rest of the program expects.</li>
                  <li>4 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 2 &mdash; Containers <span class="ticket-count">5 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Build, tag, and run Docker containers with production-quality Dockerfiles.</li>
                  <li>Multi-stage builds to minimize image size and attack surface.</li>
                  <li>Container security fundamentals: non-root users, read-only filesystems, secret handling.</li>
                  <li>5 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 3 &mdash; Kubernetes <span class="ticket-count">6 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Deploy services to a real Kubernetes cluster.</li>
                  <li>Configure ingress, RBAC, resource limits, and horizontal pod autoscaling.</li>
                  <li>Write manifests that production engineers would actually review.</li>
                  <li>6 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 4 &mdash; Observability <span class="ticket-count">4 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Instrument the viro-services stack with Prometheus metrics and alerting rules.</li>
                  <li>Configure structured log shipping from pods to a central collector.</li>
                  <li>Build the Grafana dashboard your on-call rotation will actually use.</li>
                  <li>4 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 5 &mdash; CI/CD <span class="ticket-count">4 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Build GitHub Actions pipelines: lint, test, build, push, deploy.</li>
                  <li>Configure ArgoCD for GitOps-driven deployments to Kubernetes.</li>
                  <li>Rollback strategy and deployment health gates.</li>
                  <li>4 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 6 &mdash; Infrastructure as Code <span class="ticket-count">4 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Terraform modules for cloud resources &mdash; structured the way real teams maintain them.</li>
                  <li>Helm chart authoring for the viro-services workload.</li>
                  <li>Remote state, variable files, and environment separation.</li>
                  <li>4 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 7 &mdash; Security &amp; Reliability <span class="ticket-count">4 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Kubernetes NetworkPolicies: least-privilege pod-to-pod communication.</li>
                  <li>Secret management with sealed secrets or external secrets operator.</li>
                  <li>Define and instrument SLOs for the viro-services stack.</li>
                  <li>4 tickets. Each one ships to GitHub.</li>
                </ul>
              </div>
            </details>
            <details class="accordion">
              <summary>Phase 8 &mdash; Interview Readiness <span class="ticket-count">2 tickets</span></summary>
              <div class="accordion-body">
                <ul>
                  <li>Resume and LinkedIn rebuild: artifacts first, GitHub portfolio front and center.</li>
                  <li>Mock interview session with written debrief and improvement plan.</li>
                  <li>2 tickets. Both reviewed by Rohith directly.</li>
                </ul>
              </div>
            </details>
          </div>

          <p class="see-all"><a href="#schedule">See all 33 tickets &rarr;</a></p>

          <div class="repos-block">
            <h3>The three repositories</h3>
            <div class="repos-grid">
              <div class="repo-card card">
                <p class="repo-name">viro-services</p>
                <p class="repo-desc">The microservices application you build and operate.</p>
              </div>
              <div class="repo-card card">
                <p class="repo-name">viro-tooling</p>
                <p class="repo-desc">Observability stack, CI pipelines, alerting rules.</p>
              </div>
              <div class="repo-card card">
                <p class="repo-name">viro-infra</p>
                <p class="repo-desc">Terraform modules and Helm charts &mdash; infrastructure as code.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 7 — WHAT'S INCLUDED ──────────────────────── -->
      <section id="includes" class="s-includes s-padded" data-section data-section-index="6">
        <div class="inner">
          <h2>What $1,500 CAD Includes</h2>

          <ul class="inclusion-list">
            <li>8-phase program manual &mdash; 400+ pages, structured reading order</li>
            <li>Access to 3 GitHub repositories (viro-services, viro-tooling, viro-infra)</li>
            <li>33 executed, reviewed tickets in your GitHub history</li>
            <li>8 live group sessions over program duration</li>
            <li>Async coaching &mdash; dedicated Slack channel, responses within 24 hours</li>
            <li>Resume and LinkedIn rebuild &mdash; artifacts-first</li>
            <li>Mock interviews &mdash; minimum 2 sessions, written debrief per session</li>
            <li>Support until you have an offer &mdash; no time cap</li>
            <li>Manual available standalone for $699 &mdash; included in program at no extra charge</li>
          </ul>

          <div class="not-included">
            <h3>What&rsquo;s Not Included</h3>
            <ul class="exclusion-list">
              <li>A job placement guarantee. The work is yours. We do every step from study to Day 90.</li>
              <li>Visa, immigration, or work-permit support. That is a separate process.</li>
              <li>Programming fundamentals. Assumed prior. See FAQ if uncertain whether you&rsquo;re ready.</li>
              <li>Hand-holding without effort. The program is intense &mdash; see FAQ.</li>
            </ul>
          </div>

          <p class="guarantee">Complete the program and don&rsquo;t feel ready &mdash; rejoin the next cohort free.</p>
        </div>
      </section>

      <!-- ─── SECTION 8 — HOW IT WORKS ──────────────────────────── -->
      <section id="flow" class="s-flow s-padded s-alt" data-section data-section-index="7">
        <div class="inner">
          <h2>How It Works &mdash; Ten Stages, Discovery to Day 90</h2>
          <p class="section-sub">Every stage is structured. You always know where you are and what comes next.</p>

          <div class="accordion-group">
            <details class="accordion">
              <summary><span class="stage-letter">A</span> Discovery call</summary>
              <div class="accordion-body">
                <p>30-minute fit assessment. We learn where you are; you learn exactly what you&rsquo;re committing to. No hard sell. If the program isn&rsquo;t right, we tell you.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">B</span> Welcome bundle</summary>
              <div class="accordion-body">
                <p>Manual PDF, repository access, cohort Slack invite. Everything you need before you open a terminal.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">C</span> Read the manual</summary>
              <div class="accordion-body">
                <p>Structured reading. Phase by phase. No skipping. The depth you build here is what separates you in interviews. The manual is the program.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">D</span> Weekly group sessions</summary>
              <div class="accordion-body">
                <p>8 live sessions over the program. Real questions, real answers. Not recorded-and-posted content you watch alone at 1.5&times; speed. Live.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">E</span> Set up, fork, ship</summary>
              <div class="accordion-body">
                <p>Execute all 33 tickets. Each one reviewed. Each one committed to your GitHub history. This is the work. You cannot shortcut it.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">F</span> Resume + LinkedIn rebuild</summary>
              <div class="accordion-body">
                <p>Artifacts first. Your GitHub becomes the proof. The resume points to it. No empty buzzwords. No generic objective statements.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">G</span> Pre-interview prep</summary>
              <div class="accordion-body">
                <p>Mock interviews. Behavioral coaching. You walk in with a prepared answer, not a blank mind. Written debrief after every session.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">H</span> Offer</summary>
              <div class="accordion-body">
                <p>Negotiation support. You don&rsquo;t accept the first number alone. We help you evaluate the offer, understand the total comp, and respond.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">I</span> Day 1 in your new role</summary>
              <div class="accordion-body">
                <p>Onboarding checklist. What to learn, who to meet, what not to break in week one. Built from real production onboarding experience.</p>
              </div>
            </details>
            <details class="accordion">
              <summary><span class="stage-letter">J</span> Day 90 follow-up</summary>
              <div class="accordion-body">
                <p>Check-in at 90 days. Continued support. The relationship doesn&rsquo;t end at the offer letter.</p>
              </div>
            </details>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 9 — FOUNDER ────────────────────────────────── -->
      <section id="founder" class="s-founder s-padded" data-section data-section-index="8">
        <div class="inner founder-inner">
          <p class="founder-location">YAROVA IS BUILT AND RUN IN LANGLEY, BRITISH COLUMBIA.</p>
          <!-- TODO: Replace with actual founder portrait (1024×1024) before launch -->
          <Image
            src={FounderPhoto}
            alt="Rohith Yadla, Founder of Yarova"
            width={200}
            height={200}
            class="founder-photo"
          />
          <div class="founder-bio">
            <p class="founder-name">Rohith Yadla</p>
            <p class="founder-role">Solutions Architect &middot; Founder</p>
            <p>
              Yarova is an IT placement consultancy for the AI era.<br />
              The manual, the repositories, the cluster, and the curriculum<br />
              are all built and run by Rohith Yadla &mdash; Solutions Architect<br />
              with 10 years of production consulting experience across:
            </p>
            <ul class="founder-anchors">
              <li>Morgan Stanley &mdash; financial systems consulting, trading infrastructure at scale</li>
              <li>Salesforce &mdash; platform engineering consulting, enterprise Kubernetes and cloud</li>
              <li>BC Government &mdash; Solutions Architect consulting, public sector infrastructure spanning 12+ ministries</li>
            </ul>
            <p>On-call rotations. Systems handling money, traffic, and customer data. Real production pressure.</p>
            <blockquote class="founder-quote">
              &ldquo;The work is yours. The navigation is ours &mdash; every step from study to resume to interview to background check to Day&nbsp;1.&rdquo;
            </blockquote>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 10 — PRICING + FAQ + FINAL CTA ────────────── -->
      <section id="schedule" class="s-schedule s-padded s-alt" data-section data-section-index="9">
        <div class="inner">

          <!-- Pricing -->
          <div class="pricing-card">
            <h2>Pricing</h2>
            <p class="pricing-descriptor">One price. Everything included.<br />No upsells. No hidden fees. Support until you have an offer.</p>
            <div class="pricing-amount">
              <span class="price-type">ONE-TIME</span>
              <span class="price-value">$1,500 CAD</span>
            </div>
            <p class="pricing-terms">6 months access &middot; support until offer</p>
            <button type="button"
              data-cal-link="yarova-fxqeea/discovery-call"
              data-cal-origin="https://cal.com"
              class="btn btn-primary btn-lg">
              Reserve your seat
            </button>
            <p class="pricing-guarantee">Complete the program and don&rsquo;t feel ready &mdash; rejoin the next cohort free.</p>
          </div>

          <!-- FAQ -->
          <div class="faq-block">
            <h2>Questions</h2>

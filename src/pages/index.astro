    <script>
      // Animated counters
      const observe = (el, fn) => {
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => { if (e.isIntersecting) { fn(e.target); io.unobserve(e.target); } });
        }, { threshold: 0.3 });
        io.observe(el);
      };
      document.querySelectorAll('[data-count]').forEach(el => {
        const target = parseFloat(el.dataset.count);
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        observe(el, () => {
          const duration = 1100;
          const start = performance.now();
          const tick = (now) => {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            const val = Math.round(target * eased);
            el.textContent = prefix + val + suffix;
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      });

      // Countdown
      (function(){
        const el = document.getElementById('countdown');
        if (!el) return;
        const target = new Date();
        target.setDate(target.getDate() + 14);
        const fmt = (n) => String(n).padStart(2, '0');
        const update = () => {
          const ms = target - new Date();
          if (ms <= 0) { el.textContent = 'now'; return; }
          const d = Math.floor(ms / 86400000);
          const h = Math.floor((ms % 86400000) / 3600000);
          const m = Math.floor((ms % 3600000) / 60000);
          el.textContent = `in ${d}d ${fmt(h)}h ${fmt(m)}m`;
        };
        update(); setInterval(update, 30000);
      })();

      // Preferences
      const prefs = document.getElementById('prefs');
      const toggle = document.getElementById('prefsToggle');
      if (toggle && prefs) {
        toggle.addEventListener('click', () => {
          const open = prefs.classList.toggle('open');
          toggle.setAttribute('aria-expanded', open);
        });
      }
      document.querySelectorAll('.switch').forEach(s => {
        const mode = s.dataset.mode;
        const saved = localStorage.getItem('yarova-pref-' + mode) === '1';
        if (saved) { s.setAttribute('aria-checked', 'true'); document.body.classList.add('mode-' + mode); }
        const flip = () => {
          const on = s.getAttribute('aria-checked') !== 'true';
          s.setAttribute('aria-checked', on);
          document.body.classList.toggle('mode-' + mode, on);
          localStorage.setItem('yarova-pref-' + mode, on ? '1' : '0');
        };
        s.addEventListener('click', flip);
        s.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); flip(); } });
      });
    </script>


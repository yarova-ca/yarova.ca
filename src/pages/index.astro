---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "EducationalOccupationalProgram",
            "@id": "https://yarova.ca/#program",
            "name": "Yarova DevOps & SRE Experience Program",
            "description": "Real DevOps and SRE team experience for IT professionals. Async. Month to month. $799/month.",
            "provider": {
              "@type": "Organization",
              "name": "Yarova Inc.",
              "url": "https://yarova.ca",
              "address": {
                "@type": "PostalAddress",
                "addressLocality": "Langley",
                "addressRegion": "BC",
                "addressCountry": "CA"
              }
            },
            "occupationalCategory": "DevOps Engineer, Site Reliability Engineer",
            "educationalProgramMode": "online",
            "offers": {
              "@type": "Offer",
              "price": "799",
              "priceCurrency": "CAD",
              "priceValidUntil": "2027-12-31"
            }
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "What exactly is Yarova?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "A paid engineering team you join to get real production experience. $799/month pays your veteran Team Lead. You work on real tickets, real infrastructure, and real code reviews. Your work goes on GitHub permanently."
                }
              },
              {
                "@type": "Question",
                "name": "Is this real work or a simulation?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Real. The infrastructure runs on live AWS accounts. The tickets have real acceptance criteria and a real reviewer. The only thing not real: you are not on Yarova's payroll."
                }
              },
              {
                "@type": "Question",
                "name": "Why $799/month?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "It pays the Team Lead. Senior engineers cost money. Yarova charges only what covers that cost."
                }
              },
              {
                "@type": "Question",
                "name": "Can I cancel anytime?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Month to month. No penalty. No lock-in."
                }
              }
            ]
          }
        ]
      }
    </script>
  </head>

  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Header />

    <main id="main">

      <!-- ─── HERO ─── -->
      <section class="hero">
        <div class="container">

          <p class="eyebrow">
            <span class="dot-green"></span>
            DevOps &amp; SRE &middot; Canada &middot; $799/month &middot; Cancel Anytime
          </p>

          <h1>
            You want to work at a real job just to get experience.<br />
            <span class="acc">The catch is: Nobody will hire you without it.</span>
          </h1>

          <p class="hero-sub">
            Yarova breaks that loop.<br />
            $799 a month pays your Team Lead.<br />
            Everything else is exactly what a real DevOps or SRE job looks like.
          </p>

          <div class="actions">
            <a href="https://cal.com/yarova-fxqeea/discovery-call"
               target="_blank" rel="noopener"
               data-cal-link="yarova-fxqeea/discovery-call"
               data-cal-namespace="discovery-call"
               data-cal-config='{"layout":"month_view"}'
               class="btn btn-amber btn-lg">
              Book a Free 30-Min Call <span class="arrow">&rarr;</span>
            </a>
          </div>

          <p class="fine">Month to month &middot; Cancel anytime &middot; 3 months recommended</p>

        </div>
      </section>

      <!-- ─── THE PROBLEM ─── -->
      <section class="section alt" id="problem">
        <div class="container narrow">

          <h2>The interview question that ends it every time.</h2>

          <div class="quote-block">
            &ldquo;Tell me about something you shipped to production.&rdquo;
          </div>

          <p class="body-text">You freeze.</p>
          <p class="body-text">Not because you don&rsquo;t know the work.<br />Because you have never been inside a real system when it matters.</p>
          <p class="body-text">You have studied. You have certificated. You have watched tutorials.</p>
          <p class="body-text">Hiring managers spot that in 10 seconds.<br />The only thing they trust is a GitHub history with real commits from a real team.</p>

          <div class="loop-block">
            <div class="loop-line">You cannot build that without being hired.</div>
            <div class="loop-line acc-line">You cannot get hired without it.</div>
            <div class="loop-exit">Yarova is the exit from that loop.</div>
          </div>

        </div>
      </section>

      <!-- ─── HOW IT WORKS ─── -->
      <section class="section" id="how-it-works">
        <div class="container">

          <div class="sec-label">How It Works</div>
          <h2>This is not a course.<br />This is a job you pay to join.</h2>

          <div class="how-grid">
            <div class="how-item">
              <span class="how-n">01</span>
              <div class="how-body">
                <div class="how-title">Join a project team of four engineers.</div>
              </div>
            </div>
            <div class="how-item">
              <span class="how-n">02</span>
              <div class="how-body">
                <div class="how-title">Get a veteran Team Lead who has done this for years.</div>
              </div>
            </div>
            <div class="how-item">
              <span class="how-n">03</span>
              <div class="how-body">
                <div class="how-title">Pull tickets from a live backlog &mdash; real problems, real scope.</div>
              </div>
            </div>
            <div class="how-item">
              <span class="how-n">04</span>
              <div class="how-body">
                <div class="how-title">Deploy to real cloud infrastructure, not a sandbox.</div>
              </div>
            </div>
            <div class="how-item">
              <span class="how-n">05</span>
              <div class="how-body">
                <div class="how-title">Your code gets reviewed line by line by your Team Lead.</div>
              </div>
            </div>
            <div class="how-item how-item-final">
              <span class="how-n">06</span>
              <div class="how-body">
                <div class="how-title">Every commit goes on your GitHub. Permanently.</div>
              </div>
            </div>
          </div>

          <div class="how-meta">
            <div class="how-meta-item">
              <div class="how-meta-label">Status calls</div>
              <div class="how-meta-val">Scheduled twice a week. Attend if you can. If you can&rsquo;t: drop an update on your ticket and keep moving.</div>
            </div>
            <div class="how-meta-item">
              <div class="how-meta-label">Your schedule</div>
              <div class="how-meta-val">Async. Work when you have time. The work is real. The timeline is yours.</div>
            </div>
          </div>

        </div>
      </section>

      <!-- ─── THE TWO TRACKS ─── -->
      <section class="section alt" id="tracks">
        <div class="container">

          <div class="sec-label">Two Tracks</div>
          <h2>Pick the track that fits where you want to go.</h2>

          <div class="tracks-grid">

            <div class="track-card">
              <div class="track-tag">DevOps &amp; DevSecOps</div>
              <div class="track-desc">Build, automate, and secure the pipeline that ships software.</div>
              <div class="track-owns">
                <div class="track-owns-label">You own:</div>
                <ul>
                  <li>CI/CD &mdash; the automated pipeline that builds and ships code</li>
                  <li>Infrastructure as Code with Terraform</li>
                  <li>Container security and image promotion</li>
                </ul>
              </div>
              <div class="track-stack">AWS &middot; Terraform &middot; GitHub Actions &middot; Kubernetes &middot; Docker</div>
            </div>

            <div class="track-card">
              <div class="track-tag">Site Reliability Engineering (SRE)</div>
              <div class="track-desc">Keep production systems alive, observable, and self-healing.</div>
              <div class="track-owns">
                <div class="track-owns-label">You own:</div>
                <ul>
                  <li>Telemetry &mdash; metrics, logs, traces</li>
                  <li>Incident response and on-call runbooks</li>
                  <li>Error budgets &mdash; how much downtime is acceptable</li>
                </ul>
              </div>
              <div class="track-stack">AWS &middot; Kubernetes &middot; Prometheus &middot; Grafana &middot; PagerDuty</div>
            </div>

          </div>

          <div class="shared-foundation">
            <div class="sf-label">Shared foundation &mdash; both tracks</div>
            <p class="sf-desc">Before either track begins, the base infrastructure is built together.</p>
            <div class="sf-items">
              <span>Virtual networks (VPCs)</span>
              <span>Identity and access permissions (IAM)</span>
              <span>The Kubernetes cluster both tracks run on</span>
            </div>
            <div class="sf-stack">Stack: AWS &middot; Terraform</div>
          </div>

          <div class="track-proof">
            Every ticket you complete is a real commit on your GitHub.<br />
            Hiring managers open it. They inspect it. It holds up.
          </div>

        </div>
      </section>

      <!-- ─── 90-DAY JOURNEY ─── -->
      <section class="section" id="journey">
        <div class="container">

          <div class="sec-label">The 90-Day Journey</div>
          <h2>Three months. First principles to expert.</h2>

          <div class="months-grid">

            <div class="month-card">
              <div class="month-n">Month 1</div>
              <div class="month-title">First Principles</div>
              <p class="month-desc">You learn why systems are built this way, not just how to follow a tutorial.</p>
              <p class="month-desc">You ask: why this tool? why this architecture? why this decision?<br />Your Team Lead answers every question in code review.</p>
              <div class="month-outcome">By end of Month 1: you understand how production systems actually work.</div>
            </div>

            <div class="month-card">
              <div class="month-n">Month 2</div>
              <div class="month-title">You Own Tickets</div>
              <p class="month-desc">You pull real tickets. You make real decisions.<br />You deal with deployment failures, broken pipelines, and system alerts.<br />You defend your choices in code review.</p>
              <div class="month-outcome">By end of Month 2: you have stories. Real ones. With consequences.</div>
            </div>

            <div class="month-card month-card-dark">
              <div class="month-n">Month 3</div>
              <div class="month-title">Expert Level</div>
              <p class="month-desc">You tackle specialist-level tickets.<br />The hard problems. The edge cases. The architectural trade-offs.</p>
              <div class="month-outcome month-outcome-light">By end of Month 3: no interview question catches you off guard.<br />Because you have lived the answer.</div>
            </div>

          </div>

        </div>
      </section>

      <!-- ─── PRICING ─── -->
      <section class="section alt" id="pricing">
        <div class="container narrow">

          <div class="sec-label">Pricing</div>
          <h2>Simple. Honest. Justified.</h2>

          <div class="price-card">

            <div class="price-top">
              <div class="price-num">$799 <span class="ccy">/ month</span></div>
              <div class="price-when">Month to month &middot; Cancel anytime</div>
            </div>

            <div class="price-cols">

              <div class="price-col">
                <div class="price-col-label">What that pays for</div>
                <ul class="price-list">
                  <li>Your veteran Team Lead&rsquo;s time.</li>
                  <li>Real cloud infrastructure.</li>
                  <li>Real ticket reviews.</li>
                  <li>Real status calls.</li>
                </ul>
              </div>

              <div class="price-col">
                <div class="price-col-label price-col-label-neg">What it does not pay for</div>
                <ul class="price-list price-list-neg">
                  <li>Not a course.</li>
                  <li>Not pre-recorded videos.</li>
                  <li>Not a certificate.</li>
                </ul>
              </div>

            </div>

            <div class="price-recommended">
              <span class="pr-badge">Recommended</span>
              <div class="pr-text">
                3 months covers everything &mdash; first principles to expert.<br />
                Less than 3 months = incomplete work.<br />
                You can stay longer. Still month to month.
              </div>
            </div>

            <div class="price-probono">
              <span class="pb-label">Pro-bono</span>
              <p>A select number of spots per year are fully free.<br />Our mission is to upskill everyone. Money is not the filter for talent.<br />Ask on the call if you want to be considered.</p>
            </div>

            <div class="price-roi">
              <div class="roi-item"><span class="roi-n">$2,397</span><span class="roi-l">3 months total</span></div>
              <div class="roi-div">&rarr;</div>
              <div class="roi-item"><span class="roi-n">$98,000</span><span class="roi-l">Average starting salary (CAD)</span></div>
              <div class="roi-div">&rarr;</div>
              <div class="roi-item"><span class="roi-n">11 weeks</span><span class="roi-l">Average time to first offer</span></div>
            </div>

            <a href="https://cal.com/yarova-fxqeea/discovery-call"
               target="_blank" rel="noopener"
               data-cal-link="yarova-fxqeea/discovery-call"
               data-cal-namespace="discovery-call"
               data-cal-config='{"layout":"month_view"}'
               class="btn btn-amber btn-lg price-cta">
              Book a Free 30-Min Call <span class="arrow">&rarr;</span>
            </a>

          </div>

        </div>
      </section>

      <!-- ─── TRACK RECORD ─── -->
      <section class="section" id="track-record">
        <div class="container narrow" style="text-align:center;">

          <div class="sec-label" style="justify-content:center;">Track Record</div>
          <h2>Numbers. No names.</h2>

          <div class="stats-grid">
            <div class="stat">
              <div class="stat-n">47</div>
              <div class="stat-l">Engineers placed<br />since 2022</div>
            </div>
            <div class="stat">
              <div class="stat-n">$98K</div>
              <div class="stat-l">CAD average<br />starting salary</div>
            </div>
            <div class="stat">
              <div class="stat-n">11 wks</div>
              <div class="stat-l">Average time to<br />first job offer</div>
            </div>
          </div>

          <p class="stats-note">Full case studies &mdash; name, city, employer, salary &mdash; shared on the call.<br />We do not publish names without explicit consent.</p>

        </div>
      </section>

      <!-- ─── FAQ ─── -->
      <section class="section alt" id="faq">
        <div class="container narrow">

          <div class="sec-label">FAQ</div>
          <h2>Questions you should ask before booking.</h2>

          <div class="faq">

            <details open>
              <summary><span>What exactly is Yarova?</span><span class="glyph">&minus;</span></summary>
              <div class="answer">
                <p>A paid engineering team you join to get real production experience.</p>
                <p>$799/month pays your veteran Team Lead. You work on real tickets, real infrastructure, and real code reviews. Your work goes on GitHub permanently.</p>
              </div>
            </details>

            <details>
              <summary><span>Is this real work or a simulation?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Real. The infrastructure runs on live AWS accounts. The tickets have real acceptance criteria and a real reviewer.</p>
                <p>The only thing not real: you are not on Yarova&rsquo;s payroll. You are a paid participant. The work is real.</p>
              </div>
            </details>

            <details>
              <summary><span>Why $799/month?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>It pays the Team Lead. Senior engineers cost money. Yarova charges only what covers that cost.</p>
                <p>There is no markup for branding, courses, or content.</p>
              </div>
            </details>

            <details>
              <summary><span>Why do you recommend 3 months?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Month 1 builds understanding. Month 2 builds ownership. Month 3 builds expert depth.</p>
                <p>Leaving after Month 1 or 2 means leaving before the hardest and most valuable work. Month to month means you decide. We recommend 3.</p>
              </div>
            </details>

            <details>
              <summary><span>Can I cancel anytime?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Yes. Month to month. No penalty. No lock-in.</p>
              </div>
            </details>

            <details>
              <summary><span>Do I need to attend the status calls?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Recommended. Not required.</p>
                <p>If you miss: drop an async update on your ticket. The Team Lead reviews it. Work continues.</p>
              </div>
            </details>

            <details>
              <summary><span>What if I already have a job?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Join. Work on your own schedule. Status calls are twice a week &mdash; attend when you can.</p>
                <p>Async work fits around a day job.</p>
              </div>
            </details>

            <details>
              <summary><span>Will this work pass a Canadian background check?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Yes. Yarova Inc. is a registered Canadian company in British Columbia.</p>
                <p>We provide a formal verification letter. We serve as your reference. We answer when the background check company calls.</p>
                <p>List your role as: <strong>Independent Technical Fellow (Uncompensated) &mdash; Yarova Inc.</strong></p>
              </div>
            </details>

            <details>
              <summary><span>Are there pro-bono spots?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>Yes. A select number each year.</p>
                <p>Ask on the discovery call. We assess fit first. If the fit is right and the need is real, we make it work.</p>
              </div>
            </details>

            <details>
              <summary><span>Does this count toward Canadian PR or Express Entry?</span><span class="glyph">+</span></summary>
              <div class="answer">
                <p>No. Yarova is an uncompensated practicum. IRCC does not count unpaid work for CEC (Canadian Experience Class) hours.</p>
                <p>What Yarova does: gives you the depth to pass a TEER 1 technical interview. That job earns the CRS score. Not this.</p>
              </div>
            </details>

          </div>

        </div>
      </section>

      <!-- ─── FINAL CTA ─── -->
      <section class="cta-final" id="book">
        <div class="container narrow" style="text-align:center;">

          <h2>Book a free 30-minute call.</h2>

          <div class="cta-bullets">
            <span>No payment on the call.</span>
            <span>We confirm the right track and start date.</span>
            <span>You decide after.</span>
          </div>

          <div class="actions" style="justify-content:center; margin-top:40px;">
            <a href="https://cal.com/yarova-fxqeea/discovery-call"
               target="_blank" rel="noopener"
               data-cal-link="yarova-fxqeea/discovery-call"
               data-cal-namespace="discovery-call"
               data-cal-config='{"layout":"month_view"}'
               class="btn btn-amber btn-lg">
              Book a Free 30-Min Call <span class="arrow">&rarr;</span>
            </a>
            <a href="mailto:hello@yarova.ca" class="btn btn-ghost btn-lg ghost-light">Email us instead</a>
          </div>

          <div class="cta-contact">
            <span>WhatsApp: <a href="https://wa.me/16047197918" target="_blank" rel="noopener">+1 (604) 719-7918</a> &middot; Mon&ndash;Fri 9:00&ndash;18:00 PT</span>
            <span>Email: <a href="mailto:hello@yarova.ca">hello@yarova.ca</a></span>
          </div>

        </div>
      </section>

    </main>

    <Footer />

    <!-- Floating actions -->
    <div class="floating-actions" aria-label="Quick contact">
      <a class="fa-btn wa"
         href="https://wa.me/16047197918?text=Hi%20Yarova%2C%20I%27d%20like%20to%20learn%20about%20the%20program."
         target="_blank" rel="noopener" aria-label="WhatsApp">
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.46 1.32 4.96L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01Zm-7.01 15.24c-1.48 0-2.94-.4-4.21-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.26 8.26 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24a8.18 8.18 0 0 1 8.24 8.24c.01 4.54-3.69 8.24-8.22 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12s-.64.81-.78.97c-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43-.14-.01-.31-.01-.48-.01-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.05-.11-.21-.17-.45-.29Z"/>
          </svg>
        </span>
        <span class="lbl">WhatsApp</span>
      </a>
      <a class="fa-btn cal"
         href="https://cal.com/yarova-fxqeea/discovery-call"
         target="_blank" rel="noopener"
         data-cal-link="yarova-fxqeea/discovery-call"
         data-cal-namespace="discovery-call"
         data-cal-config='{"layout":"month_view"}'
         aria-label="Book a call">
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="16" rx="2"/>
            <path d="M16 3v4M8 3v4M3 10h18"/>
          </svg>
        </span>
        <span class="lbl">Book a call</span>
      </a>
    </div>

    <!-- Cal.com embed -->
    <script type="text/javascript">
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "Cal");
      Cal("init", "discovery-call", {origin:"https://cal.com"});
      Cal.ns["discovery-call"]("ui", {hideEventTypeDetails:false, layout:"month_view", styles:{branding:{brandColor:"#B45309"}}});
    </script>

    <!-- FAQ toggle glyphs -->
    <script>
      document.querySelectorAll('.faq details').forEach(function(d) {
        d.addEventListener('toggle', function() {
          var g = d.querySelector('.glyph');
          if (g) g.textContent = d.open ? '−' : '+';
        });
      });
    </script>

    <style>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { animation: none !important; transition: none !important; }
      }

      a { color: var(--color-amber-hover); text-decoration: none; }
      a:hover { color: var(--color-amber-press); }
      a:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(217,119,6,.28); border-radius: 4px; }
      .skip { position: absolute; left: -9999px; top: 8px; background: var(--color-black); color: white; padding: 10px 14px; border-radius: 8px; font-size: 14px; z-index: 999; }
      .skip:focus { left: 12px; }

      .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
      .container.narrow { max-width: 720px; }
      .section { padding: 96px 0; border-top: 1px solid var(--border); }
      .section.alt { background: var(--bg-secondary); }

      h1, h2, h3 { font-family: var(--font-sans); margin: 0; color: var(--fg-1); letter-spacing: -.025em; }
      h1 { font-size: clamp(32px, 5.2vw, 68px); font-weight: 700; line-height: 1.05; letter-spacing: -.035em; }
      h2 { font-size: clamp(26px, 3.8vw, 46px); font-weight: 700; line-height: 1.1; }
      p { margin: 0; color: var(--fg-2); line-height: 1.65; }

      .btn { display: inline-flex; align-items: center; gap: 10px; padding: 14px 22px; border-radius: 999px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; line-height: 1; border: 1px solid transparent; cursor: pointer; transition: transform 120ms ease, background 150ms ease; text-decoration: none; }
      .btn-lg { padding: 18px 30px; font-size: 16px; }
      .btn-amber { background: var(--color-amber-hover); color: white !important; box-shadow: 0 8px 22px -10px rgba(217,119,6,.55); }
      .btn-amber:hover { background: var(--color-amber-press); color: white !important; transform: translateY(-1px); }
      .btn-ghost { background: transparent; color: var(--fg-1); border-color: var(--border); }
      .btn-ghost:hover { color: var(--fg-1); border-color: var(--border-hover); }
      .ghost-light { color: rgba(255,255,255,.8) !important; border-color: rgba(255,255,255,.2) !important; }
      .ghost-light:hover { color: white !important; border-color: rgba(255,255,255,.4) !important; }
      .btn .arrow { transition: transform 180ms ease; display: inline-block; }
      .btn:hover .arrow { transform: translateX(3px); }

      .sec-label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
      .sec-label::before { content: ""; width: 20px; height: 1px; background: var(--color-amber-hover); }

      /* Hero */
      .hero { padding: 88px 0 80px; }
      .eyebrow { font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); margin-bottom: 36px; display: flex; align-items: center; gap: 10px; }
      .dot-green { width: 8px; height: 8px; border-radius: 50%; background: #10B981; box-shadow: 0 0 0 3px rgba(16,185,129,.2); flex-shrink: 0; }
      .hero h1 .acc { color: var(--color-amber-hover); }
      .hero-sub { font-size: 20px; color: var(--fg-2); margin-top: 32px; max-width: 640px; line-height: 1.6; }
      .actions { display: flex; gap: 14px; margin-top: 36px; flex-wrap: wrap; }
      .fine { font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; color: var(--fg-3); margin-top: 14px; }

      /* Problem */
      .quote-block { margin: 40px 0 36px; padding: 28px 32px; background: var(--color-black); color: rgba(255,255,255,.9); border-radius: 12px; font-size: clamp(18px, 2.8vw, 26px); font-weight: 600; letter-spacing: -.015em; line-height: 1.35; font-family: var(--font-mono); }
      .body-text { font-size: 17px; color: var(--fg-1); line-height: 1.7; margin-bottom: 20px; }
      .loop-block { margin-top: 44px; padding: 28px 32px; border-left: 3px solid var(--color-amber-hover); background: var(--bg-secondary); border-radius: 0 12px 12px 0; }
      .loop-line { font-size: 18px; font-weight: 500; color: var(--fg-1); margin-bottom: 8px; }
      .acc-line { color: var(--color-amber-hover); font-weight: 700; }
      .loop-exit { margin-top: 20px; font-size: 16px; color: var(--fg-2); padding-top: 20px; border-top: 1px solid var(--border); }

      /* How It Works */
      .how-grid { margin-top: 48px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
      .how-item { padding: 28px 24px; background: var(--bg-primary); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); display: flex; gap: 16px; }
      .how-item:nth-child(3n) { border-right: none; }
      .how-item:nth-child(4), .how-item:nth-child(5), .how-item:nth-child(6) { border-bottom: none; }
      .how-item-final { background: var(--color-black); }
      .how-item-final .how-n { color: var(--color-amber); }
      .how-item-final .how-title { color: white; }
      .how-n { font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--color-amber-hover); padding-top: 2px; flex-shrink: 0; }
      .how-title { font-size: 15px; font-weight: 500; color: var(--fg-1); line-height: 1.5; }
      @media (max-width: 880px) { .how-grid { grid-template-columns: 1fr 1fr; } .how-item:nth-child(2n) { border-right: none; } .how-item:nth-child(3), .how-item:nth-child(4) { border-bottom: 1px solid var(--border); } .how-item:nth-child(5), .how-item:nth-child(6) { border-bottom: none; } }
      @media (max-width: 560px) { .how-grid { grid-template-columns: 1fr; } .how-item { border-right: none !important; border-bottom: 1px solid var(--border) !important; } .how-item:last-child { border-bottom: none !important; } }
      .how-meta { margin-top: 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
      .how-meta-item { padding: 24px; background: var(--bg-secondary); border-radius: 12px; border: 1px solid var(--border); }
      .how-meta-label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; margin-bottom: 10px; }
      .how-meta-val { font-size: 14px; color: var(--fg-2); line-height: 1.6; }
      @media (max-width: 640px) { .how-meta { grid-template-columns: 1fr; } }

      /* Tracks */
      .tracks-grid { margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .track-card { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 14px; padding: 32px; }
      .track-tag { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; margin-bottom: 12px; }
      .track-desc { font-size: 16px; font-weight: 500; color: var(--fg-1); margin-bottom: 20px; line-height: 1.5; }
      .track-owns-label { font-size: 12px; font-weight: 600; color: var(--fg-3); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 10px; }
      .track-card ul { list-style: none; padding: 0; margin: 0 0 20px; display: flex; flex-direction: column; gap: 8px; }
      .track-card ul li { font-size: 14px; color: var(--fg-2); padding-left: 18px; position: relative; line-height: 1.5; }
      .track-card ul li::before { content: "→"; position: absolute; left: 0; color: var(--color-amber-hover); font-size: 12px; top: 1px; }
      .track-stack { font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); letter-spacing: .06em; padding-top: 16px; border-top: 1px solid var(--border); }
      @media (max-width: 700px) { .tracks-grid { grid-template-columns: 1fr; } }
      .shared-foundation { margin-top: 24px; padding: 28px 32px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 14px; }
      .sf-label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); font-weight: 600; margin-bottom: 8px; }
      .sf-desc { font-size: 14px; color: var(--fg-2); margin-bottom: 16px; }
      .sf-items { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px; }
      .sf-items span { font-size: 13px; color: var(--fg-2); padding: 6px 12px; background: var(--bg-secondary); border-radius: 999px; border: 1px solid var(--border); }
      .sf-stack { font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); }
      .track-proof { margin-top: 24px; padding: 24px 28px; background: var(--color-black); color: rgba(255,255,255,.85); border-radius: 12px; font-size: 16px; line-height: 1.65; }

      /* 90-Day Journey */
      .months-grid { margin-top: 48px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .month-card { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 14px; padding: 32px; display: flex; flex-direction: column; gap: 16px; }
      .month-card-dark { background: var(--color-black); border-color: var(--color-black); }
      .month-n { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; }
      .month-card-dark .month-n { color: var(--color-amber); }
      .month-title { font-size: 22px; font-weight: 700; color: var(--fg-1); letter-spacing: -.02em; }
      .month-card-dark .month-title { color: white; }
      .month-desc { font-size: 14px; color: var(--fg-2); line-height: 1.65; }
      .month-card-dark .month-desc { color: rgba(255,255,255,.65); }
      .month-outcome { font-size: 14px; font-weight: 600; color: var(--fg-1); padding-top: 16px; border-top: 1px solid var(--border); line-height: 1.5; margin-top: auto; }
      .month-outcome-light { color: white; border-top-color: rgba(255,255,255,.1); }
      @media (max-width: 880px) { .months-grid { grid-template-columns: 1fr; } }

      /* Pricing */
      .price-card { margin-top: 40px; background: var(--color-black); border-radius: 20px; padding: 48px; position: relative; overflow: hidden; }
      .price-card::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at top right, rgba(217,119,6,.15), transparent 60%); pointer-events: none; }
      .price-top { position: relative; margin-bottom: 36px; }
      .price-num { font-size: clamp(48px, 8vw, 72px); font-weight: 700; color: white; letter-spacing: -.04em; line-height: 1; }
      .price-num .ccy { font-size: 22px; color: rgba(255,255,255,.5); font-weight: 500; letter-spacing: 0; }
      .price-when { font-size: 13px; color: rgba(255,255,255,.45); margin-top: 10px; font-family: var(--font-mono); letter-spacing: .06em; }
      .price-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; position: relative; }
      .price-col-label { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber); font-weight: 600; margin-bottom: 14px; }
      .price-col-label-neg { color: rgba(255,255,255,.35); }
      .price-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
      .price-list li { font-size: 15px; color: rgba(255,255,255,.8); padding-left: 22px; position: relative; line-height: 1.4; }
      .price-list li::before { content: "✓"; position: absolute; left: 0; color: var(--color-amber); font-weight: 700; }
      .price-list-neg li { color: rgba(255,255,255,.4); }
      .price-list-neg li::before { content: "—"; color: rgba(255,255,255,.2); }
      @media (max-width: 560px) { .price-cols { grid-template-columns: 1fr; } }
      .price-recommended { display: flex; align-items: flex-start; gap: 14px; padding: 20px 24px; background: rgba(217,119,6,.12); border: 1px solid rgba(217,119,6,.25); border-radius: 12px; margin-bottom: 24px; position: relative; }
      .pr-badge { flex-shrink: 0; padding: 4px 10px; background: var(--color-amber-hover); color: white; border-radius: 999px; font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; }
      .pr-text { font-size: 14px; color: rgba(255,255,255,.75); line-height: 1.6; }
      .price-probono { padding: 20px 24px; background: rgba(255,255,255,.04); border-radius: 12px; margin-bottom: 32px; position: relative; }
      .pb-label { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .14em; color: rgba(255,255,255,.4); font-weight: 600; margin-bottom: 8px; }
      .price-probono p { font-size: 14px; color: rgba(255,255,255,.6); line-height: 1.6; }
      .price-roi { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 12px; align-items: center; margin-bottom: 36px; position: relative; padding: 24px; background: rgba(255,255,255,.04); border-radius: 12px; }
      .roi-item { display: flex; flex-direction: column; gap: 4px; }
      .roi-n { font-size: clamp(20px, 3.5vw, 28px); font-weight: 700; color: white; letter-spacing: -.02em; }
      .roi-l { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.4); line-height: 1.4; }
      .roi-div { font-size: 20px; color: rgba(255,255,255,.2); text-align: center; }
      @media (max-width: 560px) { .price-roi { grid-template-columns: 1fr; } .roi-div { display: none; } }
      .price-cta { width: 100%; justify-content: center; position: relative; }

      /* Track Record */
      .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin: 48px 0 32px; }
      .stat { display: flex; flex-direction: column; gap: 8px; }
      .stat-n { font-size: clamp(36px, 6vw, 64px); font-weight: 700; color: var(--fg-1); letter-spacing: -.04em; line-height: 1; }
      .stat-l { font-size: 14px; color: var(--fg-2); line-height: 1.5; }
      .stats-note { font-size: 14px; color: var(--fg-3); line-height: 1.65; }
      @media (max-width: 560px) { .stats-grid { grid-template-columns: 1fr; } }

      /* FAQ */
      .faq { margin-top: 40px; }
      .faq details { border-bottom: 1px solid var(--border); padding: 22px 0; }
      .faq details summary { display: flex; justify-content: space-between; align-items: center; cursor: pointer; list-style: none; font-size: 17px; font-weight: 500; color: var(--fg-1); gap: 24px; }
      .faq details summary::-webkit-details-marker { display: none; }
      .glyph { font-family: var(--font-mono); font-size: 22px; color: var(--color-amber-hover); flex-shrink: 0; }
      .answer { padding-top: 16px; max-width: 640px; }
      .answer p { color: var(--fg-2); font-size: 15px; line-height: 1.7; margin-bottom: 12px; }
      .answer p:last-child { margin-bottom: 0; }
      .answer strong { color: var(--fg-1); font-weight: 600; }

      /* Final CTA */
      .cta-final { background: var(--color-black); color: white; padding: 96px 0; }
      .cta-final h2 { color: white; }
      .cta-bullets { display: flex; flex-direction: column; gap: 8px; margin-top: 24px; }
      .cta-bullets span { font-size: 16px; color: rgba(255,255,255,.65); }
      .cta-contact { margin-top: 32px; display: flex; flex-direction: column; gap: 8px; }
      .cta-contact span { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,.4); letter-spacing: .04em; }
      .cta-contact a { color: rgba(255,255,255,.7); }
      .cta-contact a:hover { color: white; }

      /* Floating actions */
      .floating-actions { position: fixed; bottom: 24px; right: 22px; z-index: 55; display: flex; flex-direction: column; gap: 10px; }
      .fa-btn { display: flex; align-items: center; gap: 10px; padding: 12px 20px; border-radius: 999px; font-size: 13px; font-weight: 600; color: white; text-decoration: none; transition: transform 120ms ease; box-shadow: 0 8px 22px -8px rgba(0,0,0,.35); }
      .fa-btn:hover { transform: translateY(-2px); color: white; }
      .fa-btn.wa { background: #25D366; }
      .fa-btn.cal { background: var(--color-black); border: 1px solid rgba(255,255,255,.15); }
      .fa-btn .ic { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; }
      .fa-btn .ic svg { width: 18px; height: 18px; }
      @media (max-width: 640px) { .fa-btn .lbl { display: none; } .fa-btn { padding: 14px; } }
    </style>
  </body>
</html>

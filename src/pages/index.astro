      .btn { display: inline-flex; align-items: center; gap: 10px; padding: 14px 22px; border-radius: 999px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; line-height: 1; border: 1px solid transparent; cursor: pointer; transition: transform 120ms ease, box-shadow 180ms ease, background 150ms; will-change: transform; text-decoration: none; }
      .btn-lg { padding: 18px 30px; font-size: 16px; }
      .btn-amber { background: var(--color-amber-hover); color: white; box-shadow: 0 1px 0 rgba(255,255,255,.15) inset, 0 8px 22px -10px rgba(217,119,6,.55); }
      .btn-amber:hover { background: var(--color-amber-press); color: white; transform: translateY(-1px); box-shadow: 0 1px 0 rgba(255,255,255,.18) inset, 0 14px 28px -10px rgba(217,119,6,.6); }
      .btn-ghost { background: transparent; color: var(--fg-1); border-color: var(--border); }
      .btn-ghost:hover { color: var(--fg-1); border-color: var(--fg-1); background: var(--bg-secondary); }
      .btn .arrow { transition: transform 180ms ease; display: inline-block; }
      .btn:hover .arrow { transform: translateX(3px); }

      /* Hero */
      .hero { padding: 96px 0 80px; position: relative; }
      .hero-eyebrow { display: flex; align-items: center; gap: 14px; font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); margin-bottom: 36px; flex-wrap: wrap; }
      .hero-eyebrow .tag { padding: 4px 10px; border: 1px solid var(--border); border-radius: 999px; color: var(--color-amber-hover); font-weight: 600; }
      .hero h1 { max-width: 1100px; }
      .hero h1 .acc { color: var(--color-amber-hover); }
      .hero-sub { font-size: 22px; color: var(--fg-2); margin-top: 32px; max-width: 760px; line-height: 1.5; text-wrap: pretty; }
      .hero-sub strong { color: var(--fg-1); font-weight: 600; }
      .hero-actions { display: flex; gap: 14px; margin-top: 40px; flex-wrap: wrap; }
      .hero-meta { margin-top: 64px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .hero-meta .cell { padding: 24px 24px 24px 0; border-right: 1px solid var(--border); }
      .hero-meta .cell:last-child { border-right: none; padding-right: 0; }
      .hero-meta .k { display: block; font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); margin-bottom: 10px; }
      .hero-meta .v { display: block; font-size: 24px; font-weight: 700; color: var(--fg-1); letter-spacing: -.02em; }
      .hero-meta .v small { font-size: 12px; font-weight: 500; color: var(--fg-3); display: block; margin-top: 4px; letter-spacing: 0; }
      @media (max-width: 760px) { .hero-meta { grid-template-columns: repeat(2, 1fr); } .hero-meta .cell { padding: 20px 16px 20px 0; } .hero-meta .cell:nth-child(2) { border-right: none; } .hero-meta .cell:nth-child(3) { padding-left: 16px; border-right: 1px solid var(--border); } }
      .hero-glow { position: absolute; top: 0; right: -200px; width: 600px; height: 600px; background: radial-gradient(circle at center, rgba(217,119,6,.10), transparent 60%); pointer-events: none; }

      /* Authority strip */
      .authority { padding: 36px 0; background: var(--color-black); color: white; }
      .authority .row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,.08); border-radius: 12px; overflow: hidden; }
      .authority .cell { padding: 28px 24px; background: var(--color-black); display: flex; flex-direction: column; gap: 8px; }
      .authority .num { font-size: 40px; font-weight: 700; line-height: 1; color: var(--color-amber); letter-spacing: -.03em; }
      .authority .lbl { font-size: 12px; color: rgba(255,255,255,.6); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .12em; }
      @media (max-width: 760px) { .authority .row { grid-template-columns: repeat(2, 1fr); } }

      /* Promise cards */
      .ensure-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 56px; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
      .ensure-card { background: var(--bg-primary); padding: 36px 32px; display: flex; flex-direction: column; gap: 20px; }
      .ensure-card .num { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber-hover); font-weight: 600; }
      .ensure-card h3 { font-size: 24px; line-height: 1.2; }
      .ensure-card .body { font-size: 15px; color: var(--fg-2); line-height: 1.6; }
      .ensure-card .why { padding-top: 16px; border-top: 1px solid var(--border); font-size: 13px; color: var(--fg-3); line-height: 1.6; }
      .ensure-card .why b { color: var(--fg-1); }
      @media (max-width: 880px) { .ensure-grid { grid-template-columns: 1fr; } }

      /* Cost box */
      .cost-box { margin-top: 48px; padding: 32px 36px; border: 2px solid var(--color-black); background: var(--color-white); border-radius: 14px; display: grid; grid-template-columns: 180px 1fr; gap: 32px; align-items: center; }
      .cost-box .lead-lbl { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); }
      .cost-box .stmt { font-size: 18px; color: var(--fg-1); line-height: 1.55; }
      .cost-box .stmt b { color: var(--color-amber-hover); }
      @media (max-width: 720px) { .cost-box { grid-template-columns: 1fr; gap: 16px; padding: 24px; } }

      /* Request path */
      .path { margin-top: 64px; }
      .path-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; background: var(--bg-secondary); }
      .path-node { padding: 24px 18px; background: var(--bg-primary); border-right: 1px solid var(--border); display: flex; flex-direction: column; gap: 10px; position: relative; }
      .path-node:last-child { border-right: none; }
      .path-node .ord { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); }
      .path-node .layer { font-size: 14px; font-weight: 600; color: var(--fg-1); letter-spacing: -.01em; }
      .path-node .topic { font-size: 11px; color: var(--fg-3); font-family: var(--font-mono); line-height: 1.5; }
      .path-node::after { content: "→"; position: absolute; right: -10px; top: 50%; transform: translateY(-50%); color: var(--color-amber-hover); font-size: 14px; background: var(--bg-secondary); padding: 0 4px; z-index: 2; font-weight: 700; }
      .path-node:last-child::after { display: none; }
      @media (max-width: 980px) { .path-grid { grid-template-columns: repeat(4, 1fr); } .path-node { border-bottom: 1px solid var(--border); } .path-node:nth-child(n+5) { border-bottom: none; } .path-node:nth-child(4)::after, .path-node:last-child::after { display: none; } }
      @media (max-width: 640px) { .path-grid { grid-template-columns: repeat(2, 1fr); } .path-node::after { display: none; } }
      .layers-detail { margin-top: 36px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
      .layer-row { background: var(--bg-primary); padding: 20px 24px; display: grid; grid-template-columns: 28px 160px 1fr; gap: 16px; align-items: baseline; }
      .layer-row .n { font-family: var(--font-mono); font-size: 12px; color: var(--color-amber-hover); font-weight: 600; }
      .layer-row .t { font-size: 15px; font-weight: 600; color: var(--fg-1); }
      .layer-row .d { font-size: 13px; color: var(--fg-2); line-height: 1.5; }
      @media (max-width: 880px) { .layers-detail { grid-template-columns: 1fr; } .layer-row { grid-template-columns: 28px 1fr; } .layer-row .d { grid-column: 2 / -1; padding-top: 4px; } }

      /* Track record */
      .track-table { width: 100%; border-collapse: collapse; margin-top: 48px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
      .track-table th, .track-table td { text-align: left; padding: 16px 20px; border-bottom: 1px solid var(--border); font-size: 14px; }
      .track-table th { background: var(--bg-secondary); font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--fg-2); font-weight: 600; }
      .track-table tr:last-child td { border-bottom: none; }
      .track-table tbody tr:hover { background: var(--bg-secondary); }
      .track-table .yr { font-family: var(--font-mono); font-weight: 600; color: var(--fg-1); }
      .track-table .pct { font-weight: 600; color: var(--color-amber-hover); }
      .track-table tfoot td { background: var(--color-black); color: white; font-weight: 600; }
      .track-table tfoot .pct { color: var(--color-amber); }
      @media (max-width: 760px) { .track-table { font-size: 12px; } .track-table th, .track-table td { padding: 10px 12px; } .track-table .hide-sm { display: none; } }
      .track-foot { margin-top: 20px; font-size: 12px; color: var(--fg-3); line-height: 1.6; }

      /* Testimonials */
      .testis { margin-top: 48px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .testi { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 14px; padding: 28px; display: flex; flex-direction: column; gap: 18px; transition: transform 220ms ease, box-shadow 220ms ease; }
      .testi:hover { transform: translateY(-3px); box-shadow: 0 22px 50px -22px rgba(0,0,0,.18); }
      .testi .quote { font-size: 15px; color: var(--fg-1); line-height: 1.6; }
      .testi .quote::before { content: "\201C"; font-family: Georgia, serif; font-size: 36px; color: var(--color-amber-hover); line-height: 0; vertical-align: -10px; margin-right: 6px; }
      .testi .meta-row { display: flex; gap: 16px; font-family: var(--font-mono); font-size: 11px; color: var(--fg-3); text-transform: uppercase; letter-spacing: .12em; padding-top: 16px; border-top: 1px solid var(--border); }
      .testi .meta-row b { color: var(--fg-1); font-weight: 600; }
      .testi .who { display: flex; align-items: center; gap: 12px; }
      .testi .avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: white; letter-spacing: -.01em; }
      .testi .name { font-size: 13px; font-weight: 600; color: var(--fg-1); }
      .testi .role { font-size: 12px; color: var(--fg-3); }
      @media (max-width: 980px) { .testis { grid-template-columns: 1fr; } }

      /* Curriculum phases */
      .phases { margin-top: 48px; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; background: var(--bg-primary); }
      .phase-row { display: grid; grid-template-columns: 60px 200px 1fr 80px; gap: 24px; padding: 22px 28px; border-bottom: 1px solid var(--border); align-items: center; }
      .phase-row:last-child { border-bottom: none; }
      .phase-row:hover { background: var(--bg-secondary); }
      .phase-row .num { font-family: var(--font-mono); font-size: 12px; color: var(--color-amber-hover); font-weight: 600; }
      .phase-row .title { font-size: 16px; font-weight: 600; color: var(--fg-1); }
      .phase-row .skills { font-size: 13px; color: var(--fg-2); line-height: 1.5; }
      .phase-row .count { font-family: var(--font-mono); font-size: 14px; color: var(--fg-1); text-align: right; font-weight: 600; }
      .phase-row .count small { display: block; font-size: 11px; color: var(--fg-3); font-weight: 400; }
      @media (max-width: 880px) { .phase-row { grid-template-columns: 40px 1fr 70px; padding: 16px 20px; } .phase-row .skills { grid-column: 2; } .phase-row .title { grid-column: 2; } }

      /* Dark section headings — explicit white override for all dark-bg sections */
      .risk h2, .risk h3, .risk h4,
      .cta-final h2, .cta-final h3, .cta-final h4,
      .seal h3, .price-card h3,
      .step-form h3 { color: white; }

      /* Risk reversal */
      .risk { background: var(--color-black); color: white; padding: 120px 0; }
      .risk h2 { font-size: clamp(40px, 5.5vw, 72px); margin: 0; }
      .risk em { color: var(--color-amber); font-style: normal; font-weight: 700; }
      .risk p { color: rgba(255,255,255,.78); font-size: 18px; line-height: 1.6; max-width: 600px; margin-top: 24px; }
      .risk-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 80px; align-items: start; }
      .seal { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); border-radius: 16px; padding: 36px; }
      .seal .stamp { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber); margin-bottom: 16px; }
      .seal h3 { color: white; font-size: 28px; line-height: 1.15; margin-bottom: 24px; }
      .seal .three { display: flex; flex-direction: column; gap: 14px; }
      .seal .row { display: grid; grid-template-columns: 32px 1fr; gap: 14px; padding: 14px 0; border-top: 1px solid rgba(255,255,255,.1); }
      .seal .row:first-child { border-top: none; padding-top: 0; }
      .seal .n { font-family: var(--font-mono); font-size: 12px; color: var(--color-amber); }
      .seal .row b { color: white; display: block; font-size: 14px; margin-bottom: 4px; }
      .seal .row span { color: rgba(255,255,255,.65); font-size: 13px; line-height: 1.5; }
      @media (max-width: 980px) { .risk-grid { grid-template-columns: 1fr; gap: 48px; } }

      /* Pricing */
      .price-wrap { margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
      .price-card { background: var(--color-black); color: white; border-radius: 16px; padding: 44px 40px; position: relative; overflow: hidden; }
      .price-card::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at top right, rgba(217,119,6,.18), transparent 60%); pointer-events: none; }
      .price-card .label { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; color: var(--color-amber); margin-bottom: 16px; position: relative; }
      .price-card h3 { color: white; font-size: 26px; margin-bottom: 24px; position: relative; }
      .price-card .price { display: flex; align-items: baseline; gap: 10px; margin-bottom: 8px; position: relative; }
      .price-card .price .num { font-size: 72px; font-weight: 700; letter-spacing: -.04em; line-height: 1; color: white; }
      .price-card .price .ccy { font-size: 18px; color: rgba(255,255,255,.65); font-weight: 500; }
      .price-card .when { font-size: 13px; color: rgba(255,255,255,.6); position: relative; }
      .price-card .actions { margin-top: 28px; display: flex; gap: 12px; flex-wrap: wrap; position: relative; }
      .price-card .reverse { margin-top: 28px; padding: 18px 20px; border: 1px solid rgba(255,255,255,.18); border-radius: 10px; font-size: 13px; color: rgba(255,255,255,.78); line-height: 1.55; position: relative; }
      .price-card .reverse b { color: var(--color-amber); display: block; margin-bottom: 6px; font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: .14em; }
      .price-list { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 16px; padding: 36px; }
      .price-list h4 { font-size: 13px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .14em; color: var(--fg-3); margin-bottom: 16px; font-weight: 600; }
      .price-list ul { margin: 0 0 8px; padding: 0; list-style: none; }
      .price-list li { padding: 9px 0 9px 28px; position: relative; font-size: 14px; color: var(--fg-1); line-height: 1.5; border-bottom: 1px solid var(--border); }
      .price-list li:last-child { border-bottom: none; }
      .price-list li::before { content: "✓"; position: absolute; left: 0; top: 9px; color: var(--color-amber-hover); font-weight: 700; }
      .price-list li.no { color: var(--fg-3); }
      .price-list li.no::before { content: "✕"; color: #C4A06B; }
      @media (max-width: 880px) { .price-wrap { grid-template-columns: 1fr; } }

      /* FAQ */
      .faq { margin-top: 48px; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; background: var(--bg-primary); }
      .faq details { border-bottom: 1px solid var(--border); }
      .faq details:last-child { border-bottom: none; }
      .faq summary { cursor: pointer; padding: 24px 28px; font-size: 16px; font-weight: 600; color: var(--fg-1); list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 16px; }
      .faq summary::-webkit-details-marker { display: none; }
      .faq summary .glyph { color: var(--color-amber-hover); font-size: 22px; transition: transform 200ms ease; flex-shrink: 0; }
      .faq details[open] summary .glyph { transform: rotate(45deg); }
      .faq .answer { padding: 0 28px 24px; font-size: 14px; line-height: 1.7; color: var(--fg-2); }
      .faq .answer p { margin-bottom: 12px; color: var(--fg-2); }
      .faq .answer p:last-child { margin-bottom: 0; }

      /* Final CTA */
      .cta-final { background: var(--color-black); color: white; padding: 120px 0; }
      .cta-final h2 { color: white; margin: 0; }
      .cta-final p { color: rgba(255,255,255,.75); font-size: 18px; max-width: 560px; margin-top: 24px; line-height: 1.6; }
      .cta-final .twin { margin-top: 56px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding-top: 56px; border-top: 1px solid rgba(255,255,255,.1); }
      .cta-final .twin .lane { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 28px; }
      .cta-final .twin h4 { color: white; font-size: 18px; margin-bottom: 8px; font-weight: 600; }
      .cta-final .twin p { font-size: 14px; color: rgba(255,255,255,.6); margin: 0 0 20px; }
      .cta-final .btn-ghost { background: transparent; color: white; border-color: rgba(255,255,255,.2); }
      .cta-final .btn-ghost:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.4); color: white; }
      @media (max-width: 760px) { .cta-final .twin { grid-template-columns: 1fr; } }

      /* Reading preferences widget */
      .prefs { position: fixed; bottom: 24px; left: 24px; z-index: 60; }
      .prefs-toggle { padding: 10px 16px; background: var(--color-black); color: white; border: none; border-radius: 999px; font-size: 13px; font-weight: 500; cursor: pointer; box-shadow: 0 8px 22px -8px rgba(0,0,0,.3); }
      .prefs-panel { display: none; position: absolute; bottom: 52px; left: 0; width: 320px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 14px; padding: 24px; box-shadow: 0 24px 64px -16px rgba(0,0,0,.18); }
      .prefs.open .prefs-panel { display: block; }
      .prefs-panel h4 { font-size: 14px; margin-bottom: 4px; }
      .prefs-panel .hint { font-size: 12px; color: var(--fg-3); margin-bottom: 16px; }
      .pref-row { display: flex; justify-content: space-between; gap: 12px; padding: 12px 0; border-top: 1px solid var(--border); }
      .pref-row .label { font-size: 13px; font-weight: 600; color: var(--fg-1); }
      .pref-row .desc { font-size: 12px; color: var(--fg-3); margin-top: 2px; }
      .switch { width: 36px; height: 20px; background: var(--color-gray-300); border-radius: 999px; position: relative; cursor: pointer; transition: background 180ms; flex-shrink: 0; }
      .switch::after { content: ""; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; background: white; border-radius: 50%; transition: transform 180ms; }
      .switch[aria-checked="true"] { background: var(--color-amber-hover); }
      .switch[aria-checked="true"]::after { transform: translateX(16px); }

      /* ND modes */
      body.mode-spacious .section { padding: 160px 0; }
      body.mode-larger { font-size: 17px; }
      body.mode-larger .lead { font-size: 21px; }
      body.mode-larger .hero-sub { font-size: 24px; }
    </style>
  </body>
</html>
